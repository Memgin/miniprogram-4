/* ==========================================
   1. 全局容器与头部
   ========================================== */
   .container {
    padding: 0 30rpx 60rpx;
    box-sizing: border-box;
    min-height: 100vh;
    background-color: #f8f9fb;
  }

  .detail-hero {
    margin-top: 20rpx;
    padding: 34rpx;
    background: linear-gradient(135deg, #102a43, #1d4ed8 56%, #0f766e);
    color: #ffffff;
    box-shadow: 0 22rpx 44rpx rgba(15, 23, 42, 0.16);
  }

  .detail-hero-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 18rpx;
  }

  .detail-hero-main {
    flex: 1;
    min-width: 0;
  }

  .detail-hero-title {
    font-size: 40rpx;
    font-weight: 700;
    line-height: 1.2;
  }

  .detail-hero-subtitle {
    margin-top: 12rpx;
    font-size: 24rpx;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.76);
  }

  .detail-hero-metrics {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14rpx;
    margin-top: 24rpx;
  }

  .detail-hero-metric {
    padding: 18rpx 20rpx;
    border-radius: 20rpx;
    background: rgba(255, 255, 255, 0.12);
    border: 1rpx solid rgba(255, 255, 255, 0.16);
  }

  .detail-hero-label {
    font-size: 22rpx;
    color: rgba(255, 255, 255, 0.72);
  }

  .detail-hero-value {
    margin-top: 10rpx;
    font-size: 30rpx;
    font-weight: 700;
    color: #ffffff;
  }

  .detail-hero-note {
    margin-top: 8rpx;
    font-size: 22rpx;
    color: rgba(255, 255, 255, 0.72);
  }

  .detail-hero-actions {
    display: flex;
    gap: 14rpx;
    margin-top: 22rpx;
    flex-wrap: wrap;
  }

  .detail-hero-btn {
    flex: 1;
    min-width: 0;
    height: 72rpx;
    line-height: 72rpx;
    border-radius: 999rpx;
    background: rgba(255, 255, 255, 0.12);
    color: #ffffff;
    font-size: 24rpx;
    border: 1rpx solid rgba(255, 255, 255, 0.18);
  }

  .detail-hero-btn-primary {
    background: #ffffff;
    color: #102a43;
  }

  .detail-hero-foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16rpx;
    margin-top: 22rpx;
    padding-top: 18rpx;
    border-top: 1rpx solid rgba(255, 255, 255, 0.14);
  }

  .detail-security-mini {
    flex-shrink: 0;
    padding: 10rpx 18rpx;
    border-radius: 999rpx;
    background: rgba(255, 255, 255, 0.12);
    border: 1rpx solid rgba(255, 255, 255, 0.18);
    font-size: 22rpx;
    color: #ffffff;
  }

  .detail-security-mini-active {
    background: #ffffff;
    color: #102a43;
  }
  
  .header {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 30rpx 0 10rpx 0;
  }

  .detail-security-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16rpx;
    margin-bottom: 20rpx;
  }

  .detail-security-copy {
    flex: 1;
    min-width: 0;
  }

  .detail-security-title {
    font-size: 26rpx;
    font-weight: 600;
    color: #ffffff;
  }

  .detail-security-subtitle {
    margin-top: 6rpx;
    font-size: 22rpx;
    color: rgba(255, 255, 255, 0.72);
  }

  .detail-eye-toggle {
    width: 72rpx;
    height: 72rpx;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.14);
    border: 1rpx solid rgba(255, 255, 255, 0.22);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .detail-eye {
    position: relative;
    width: 34rpx;
    height: 20rpx;
    border: 3rpx solid #ffffff;
    border-radius: 24rpx / 14rpx;
  }

  .detail-eye-pupil {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 10rpx;
    height: 10rpx;
    background: #ffffff;
    border-radius: 50%;
    transform: translate(-50%, -50%);
  }

  .detail-eye-off {
    opacity: 0.6;
  }

  .detail-eye-strike {
    position: absolute;
    top: 50%;
    left: -4rpx;
    width: 42rpx;
    height: 3rpx;
    background: #ffffff;
    transform: rotate(-28deg);
  }
  
  .card-name-title {
    font-size: 36rpx;
    font-weight: 600;
    color: #333;
    text-align: center;
  }
  
  .edit-icon {
    display: inline-block;
    width: 24rpx;
    height: 24rpx;
    margin-left: 10rpx;
    border: 2rpx solid #999;
    border-radius: 4rpx;
  }
  
  /* ==========================================
     2. 卡片基础与金额展示
     ========================================== */
  .card {
    background: #fff;
    border-radius: 20rpx;
    box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
    padding: 30rpx;
    box-sizing: border-box;
    margin-bottom: 24rpx;
  }

  .detail-hero.card {
    margin-top: 20rpx;
    padding: 34rpx;
    border-radius: 32rpx;
    background: linear-gradient(135deg, #102a43, #1d4ed8 56%, #0f766e);
    color: #ffffff;
    box-shadow: 0 22rpx 44rpx rgba(15, 23, 42, 0.16);
  }
  
  .card-title {
    font-size: 28rpx;
    color: #999;
    font-weight: 500;
    margin-bottom: 16rpx;
    text-align: center;
  }
  
  .total-card {
    margin-top: 10rpx;
  }
  
  /* 核心修改：人民币总计显示为原来的红色 */
  .total-amount {
    font-size: 52rpx;
    font-weight: bold;
    color: #e53935; 
    text-align: center;
  }
  
  /* ==========================================
     3. 图表 Swiper 区域 (循环滑动)
     ========================================== */
  .chart-box {
    padding: 20rpx 0 !important;
  }
  
  .swiper-container {
    height: 580rpx;
    width: 100%;
  }
  
  .chart-wrapper {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
  }
  
  .list-title {
    font-size: 30rpx;
    color: #333;
    font-weight: 600;
    padding: 0 30rpx;
    margin-bottom: 10rpx;
  }
  
  .canvas-container {
    flex: 1;
    width: 100%;
    position: relative;
  }
  
  ec-canvas {
    width: 100%;
    height: 100%;
  }
  
  .chart-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #fafafa;
  }
  
  .placeholder-text {
    font-size: 26rpx;
    color: #bbb;
  }

  .outlook-summary {
    margin-top: 8rpx;
    font-size: 26rpx;
    line-height: 1.7;
    color: #334155;
  }

  .outlook-risk {
    margin-top: 12rpx;
    font-size: 24rpx;
    color: #64748b;
  }

  .outlook-grid {
    display: flex;
    gap: 16rpx;
    margin-top: 22rpx;
  }

  .outlook-box {
    flex: 1;
    background: #f8fafc;
    border: 1rpx solid #e2e8f0;
    border-radius: 16rpx;
    padding: 22rpx;
  }

  .outlook-label {
    font-size: 22rpx;
    color: #64748b;
  }

  .outlook-value {
    margin-top: 10rpx;
    font-size: 28rpx;
    font-weight: 600;
    color: #0f172a;
  }

  .outlook-drivers {
    margin-top: 18rpx;
    display: flex;
    flex-wrap: wrap;
    gap: 12rpx;
  }

  .outlook-driver {
    padding: 10rpx 18rpx;
    border-radius: 999rpx;
    background: #eef5ff;
    color: #2f54eb;
    font-size: 22rpx;
  }

  .detail-section-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 18rpx;
  }

  .section-title-no-pad {
    padding: 0;
  }

  .detail-subtitle,
  .detail-loading {
    font-size: 23rpx;
    line-height: 1.6;
    color: #64748b;
  }

  .detail-risk-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16rpx;
    margin-top: 22rpx;
  }

  .detail-risk-box {
    padding: 20rpx;
    border-radius: 16rpx;
    background: #f8fafc;
    border: 1rpx solid #e2e8f0;
  }

  .detail-risk-label {
    font-size: 22rpx;
    color: #64748b;
  }

  .detail-risk-value {
    margin-top: 8rpx;
    font-size: 28rpx;
    font-weight: 600;
    color: #0f172a;
  }

  .detail-risk-pulse {
    margin-top: 18rpx;
    padding: 20rpx;
    border-radius: 16rpx;
    background: linear-gradient(135deg, #f8fafc, #eefbf8);
    border: 1rpx solid #dbeafe;
  }

  .detail-risk-badge {
    display: inline-flex;
    padding: 8rpx 18rpx;
    border-radius: 999rpx;
    font-size: 22rpx;
    font-weight: 600;
  }

  .detail-risk-badge-steady {
    background: #dcfce7;
    color: #15803d;
  }

  .detail-risk-badge-watch {
    background: #fef3c7;
    color: #b45309;
  }

  .detail-risk-badge-elevated {
    background: #fee2e2;
    color: #b91c1c;
  }

  .detail-risk-pulse-text {
    margin-top: 12rpx;
    font-size: 25rpx;
    line-height: 1.6;
    color: #0f172a;
  }

  .detail-risk-meta {
    margin-top: 10rpx;
    font-size: 23rpx;
    color: #64748b;
  }

  .detail-risk-signal {
    margin-top: 12rpx;
    padding-left: 18rpx;
    position: relative;
    font-size: 24rpx;
    line-height: 1.6;
    color: #334155;
  }

  .detail-risk-signal::before {
    content: '';
    position: absolute;
    left: 0;
    top: 14rpx;
    width: 8rpx;
    height: 8rpx;
    border-radius: 50%;
    background: #0f766e;
  }

  .detail-risk-focus {
    margin-top: 18rpx;
    padding: 20rpx;
    border-radius: 16rpx;
    background: linear-gradient(135deg, #fff7ed, #fffbeb);
    border: 1rpx solid #fed7aa;
  }

  .detail-risk-focus-title {
    font-size: 26rpx;
    font-weight: 600;
    color: #9a3412;
  }

  .detail-risk-focus-desc {
    margin-top: 10rpx;
    font-size: 24rpx;
    line-height: 1.6;
    color: #7c2d12;
  }

  .detail-risk-suggestion {
    margin-top: 14rpx;
    padding: 18rpx 20rpx;
    border-radius: 14rpx;
    background: rgba(255, 255, 255, 0.84);
    border: 1rpx solid #fed7aa;
  }

  .detail-risk-mode-tabs {
    display: flex;
    gap: 10rpx;
    margin-bottom: 14rpx;
    flex-wrap: wrap;
  }

  .detail-risk-mode-tab {
    padding: 8rpx 16rpx;
    border-radius: 999rpx;
    background: #ffffff;
    border: 1rpx solid #fed7aa;
    color: #9a3412;
    font-size: 22rpx;
  }

  .detail-risk-mode-tab-active {
    background: #ea580c;
    border-color: #ea580c;
    color: #ffffff;
  }

  .detail-risk-suggestion-line {
    font-size: 23rpx;
    line-height: 1.7;
    color: #7c2d12;
  }

  .detail-risk-btn {
    margin-top: 16rpx;
    height: 72rpx;
    line-height: 72rpx;
    border-radius: 999rpx;
    background: linear-gradient(135deg, #ea580c, #f59e0b);
    color: #ffffff;
    font-size: 25rpx;
  }

  .detail-risk-btn::after,
  .detail-security-pill::after,
  .add-currency-btn::after,
  .edit-btn::after {
    border: none;
  }

  .detail-risk-clear {
    display: inline-block;
    margin-top: 14rpx;
    font-size: 24rpx;
    color: #c2410c;
  }

  .detail-risk-chart-block {
    margin-top: 18rpx;
    padding: 20rpx;
    border-radius: 16rpx;
    background: #f8fafc;
    border: 1rpx solid #e2e8f0;
  }

  .detail-risk-chart-canvas {
    height: 320rpx;
    margin-top: 14rpx;
  }

  .detail-risk-rule-list {
    margin-top: 18rpx;
  }

  .detail-risk-rule-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 18rpx;
    padding: 18rpx 0;
    border-bottom: 1rpx solid #e2e8f0;
  }

  .detail-risk-rule-item:last-child {
    border-bottom: none;
  }

  .detail-risk-rule-name {
    font-size: 27rpx;
    color: #0f172a;
    font-weight: 600;
  }

  .detail-risk-rule-meta {
    margin-top: 8rpx;
    font-size: 23rpx;
    color: #64748b;
  }

  .detail-linked-highlight {
    margin-left: -12rpx;
    margin-right: -12rpx;
    padding-left: 12rpx;
    padding-right: 12rpx;
    border-radius: 14rpx;
    background: linear-gradient(135deg, #fff8db, #fff1bf);
    border-bottom-color: transparent;
  }

  .detail-alert-emphasis {
    background: linear-gradient(135deg, #ecfeff, #f0fdf4);
    box-shadow: 0 0 0 2rpx rgba(16, 185, 129, 0.18) inset;
  }

  @media (max-width: 420px) {
    .container {
      padding: 0 20rpx 44rpx;
    }

    .detail-hero.card {
      padding: 26rpx;
      border-radius: 24rpx;
    }

    .detail-hero-top {
      flex-direction: row;
      align-items: flex-start;
      gap: 14rpx;
    }

    .detail-hero-title {
      font-size: 52rpx;
      line-height: 1.18;
    }

    .detail-hero-subtitle {
      margin-top: 10rpx;
      font-size: 24rpx;
      line-height: 1.6;
    }

    .detail-eye-toggle {
      width: 62rpx;
      height: 62rpx;
    }

    .detail-hero-metrics {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12rpx;
      margin-top: 18rpx;
    }

    .detail-hero-metric {
      padding: 14rpx 16rpx;
      border-radius: 16rpx;
    }

    .detail-hero-metric:last-child {
      grid-column: 1 / -1;
    }

    .detail-hero-label {
      font-size: 21rpx;
    }

    .detail-hero-value {
      margin-top: 8rpx;
      font-size: 40rpx;
      line-height: 1.2;
    }

    .detail-hero-note {
      margin-top: 6rpx;
      font-size: 22rpx;
    }

    .detail-hero-actions {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12rpx;
      margin-top: 18rpx;
    }

    .detail-hero-btn {
      width: 100%;
      min-width: 0;
      height: 66rpx;
      line-height: 66rpx;
      font-size: 25rpx;
    }

    .detail-hero-btn-primary {
      grid-column: 1 / -1;
    }

    .detail-hero-foot,
    .detail-section-head {
      flex-direction: column;
      align-items: flex-start;
    }

    .detail-security-subtitle {
      line-height: 1.5;
    }

    .detail-risk-grid,
    .outlook-grid {
      grid-template-columns: 1fr;
      display: flex;
      flex-direction: column;
    }

    .list-title {
      padding: 0 14rpx;
    }
  }
  
  /* ==========================================
     4. 币种账户列表 (左滑删除)
     ========================================== */
  .account-list {
    margin-top: 10rpx;
  }
  
  .account-item {
    position: relative;
    background: #fff;
    border-radius: 16rpx;
    margin-bottom: 20rpx;
    box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.03);
    overflow: hidden;
  }
  
  .item-content {
    position: relative;
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 30rpx;
    box-sizing: border-box;
    background: #fff;
    z-index: 10;
    transition: transform 0.2s ease-out;
  }
  
  .account-item.show-del .item-content {
    transform: translateX(-140rpx);
  }
  
  .account-info {
    display: flex;
    flex-direction: column;
  }
  
  .currency-name {
    font-size: 32rpx;
    color: #333;
    font-weight: 600;
  }
  
  .balance-text {
    font-size: 26rpx;
    color: #999;
    margin-top: 6rpx;
  }
  
  .edit-btn {
    padding: 0 30rpx;
    height: 64rpx;
    line-height: 64rpx;
    background: #fff5eb;
    color: #ff9f43;
    font-size: 26rpx;
    border-radius: 32rpx;
    border: 1rpx solid #ff9f43;
  }
  
  .del-btn {
    position: absolute;
    right: 0;
    top: 0;
    width: 140rpx;
    height: 100%;
    background: #ff4d4f;
    color: #fff;
    font-size: 28rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 5;
  }
  
  .add-currency-btn {
    width: 100%;
    height: 94rpx;
    line-height: 94rpx;
    background: #ff9f43;
    color: #fff;
    font-size: 32rpx;
    font-weight: bold;
    border-radius: 47rpx;
    margin-top: 40rpx;
    box-shadow: 0 8rpx 20rpx rgba(255, 159, 67, 0.2);
  }
  
  /* ==========================================
     5. 弹窗样式 (优化按钮间距)
     ========================================== */
  .modal-mask {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 999;
  }
  
  .modal-content {
    width: 85%;
    background: #fff;
    border-radius: 30rpx;
    padding: 40rpx;
    box-sizing: border-box;
  }
  
  .modal-title {
    font-size: 34rpx;
    color: #333;
    text-align: center;
    margin-bottom: 40rpx;
    font-weight: bold;
  }
  
  .amount-input {
    width: 100%;
    height: 100rpx;
    background: #f7f8fa;
    border-radius: 16rpx;
    padding: 0 30rpx;
    box-sizing: border-box;
    font-size: 32rpx;
    margin-bottom: 40rpx;
  }
  
  /* 按钮组配置：增加 gap 以产生间隔 */
  .modal-btn-group {
    display: flex;
    justify-content: space-between;
    gap: 30rpx; 
    margin-top: 20rpx;
  }
  
  .modal-cancel, .modal-confirm {
    flex: 1;
    height: 88rpx;
    line-height: 88rpx;
    border-radius: 44rpx;
    font-size: 28rpx;
    font-weight: bold;
    margin: 0 !important;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .modal-cancel {
    background: #f5f5f5;
    color: #888;
  }
  
  .modal-confirm {
    background: #ff9f43;
    color: #fff;
    box-shadow: 0 4rpx 12rpx rgba(255, 159, 67, 0.2);
  }
  
  /* 币种选择器网格 */
  .currency-picker {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16rpx;
    margin-bottom: 30rpx;
  }
  
  .currency-item {
    height: 70rpx;
    line-height: 70rpx;
    text-align: center;
    background: #f5f5f5;
    border-radius: 12rpx;
    font-size: 26rpx;
    color: #666;
  }
  
  .currency-item.active {
    background: #fff5eb;
    color: #ff9f43;
    border: 1rpx solid #ff9f43;
    font-weight: bold;
  }
  
  /* 基础重置 */
  button { margin: 0; padding: 0; border: none; }
  button::after { border: none; }

  /* Liquid Glass Harmonization */
  .container {
    background:
      radial-gradient(circle at 10% -10%, rgba(143, 244, 120, 0.18) 0%, rgba(143, 244, 120, 0) 28%),
      radial-gradient(circle at 90% -8%, rgba(145, 214, 255, 0.2) 0%, rgba(145, 214, 255, 0) 28%),
      linear-gradient(170deg, #f8fbff 0%, #edf1f8 100%);
  }

  .card,
  .overview-card,
  .detail-card,
  .modal-content,
  .currency-item {
    background: linear-gradient(150deg, rgba(255, 255, 255, 0.82), rgba(255, 255, 255, 0.62));
    border: 1rpx solid rgba(255, 255, 255, 0.56);
    backdrop-filter: blur(14rpx) saturate(1.14);
    -webkit-backdrop-filter: blur(14rpx) saturate(1.14);
    box-shadow: 0 14rpx 30rpx rgba(15, 23, 42, 0.1);
  }

  .modal-confirm,
  .primary-btn,
  .detail-hero-btn-primary {
    background: linear-gradient(140deg, #151d2f, #0c1324);
    color: #ffffff;
  }

  /* System polish */
  .detail-hero,
  .detail-card,
  .modal-content,
  .overview-card {
    border-radius: 24rpx;
  }

  .detail-hero-title,
  .section-title,
  .card-name-title {
    letter-spacing: 0.2rpx;
  }

  /* Liquid Glass Unified Final Override */
  .container {
    background:
      radial-gradient(circle at 12% -8%, rgba(255, 255, 255, 0.4) 0%, rgba(255, 255, 255, 0) 30%),
      radial-gradient(circle at 90% 6%, rgba(214, 194, 168, 0.22) 0%, rgba(214, 194, 168, 0) 30%),
      linear-gradient(180deg, #f6f4f1 0%, #f1eee9 100%) !important;
  }

  .card,
  .overview-card,
  .detail-card,
  .modal-content,
  .currency-item,
  .detail-hero {
    background: linear-gradient(154deg, rgba(255, 255, 255, 0.74), rgba(247, 241, 233, 0.56)) !important;
    border: 1rpx solid rgba(255, 255, 255, 0.72) !important;
    backdrop-filter: blur(14rpx) saturate(1.03);
    -webkit-backdrop-filter: blur(14rpx) saturate(1.03);
    box-shadow: 0 10rpx 24rpx rgba(66, 53, 39, 0.09) !important;
  }

  .modal-confirm,
  .primary-btn,
  .detail-hero-btn-primary,
  .modal-cancel {
    background: linear-gradient(148deg, rgba(255, 255, 255, 0.82), rgba(243, 234, 224, 0.64)) !important;
    border: 1rpx solid rgba(255, 255, 255, 0.74) !important;
    color: #63513d !important;
  }

  .modal-confirm,
  .primary-btn,
  .detail-hero-btn-primary {
    background: linear-gradient(140deg, #7a6348, #5f4d39) !important;
    color: #fff8ef !important;
    border-color: rgba(255, 255, 255, 0.42) !important;
  }

  /* Liquid Glass Main Inspired Finish */
  .container {
    background:
      radial-gradient(circle at 14% -10%, rgba(255, 255, 255, 0.46) 0%, rgba(255, 255, 255, 0) 32%),
      radial-gradient(circle at 90% 8%, rgba(220, 198, 170, 0.22) 0%, rgba(220, 198, 170, 0) 30%),
      linear-gradient(180deg, #f6f4f1 0%, #f1eee9 100%) !important;
  }

  .card,
  .overview-card,
  .detail-card,
  .modal-content,
  .currency-item,
  .detail-hero {
    background: linear-gradient(160deg, rgba(255, 255, 255, 0.84), rgba(243, 235, 226, 0.58)) !important;
    border: 1rpx solid rgba(255, 255, 255, 0.78) !important;
    box-shadow: 0 8rpx 18rpx rgba(0, 0, 0, 0.16), 0 -16rpx 28rpx inset rgba(0, 0, 0, 0.08), 0 1rpx 0 inset rgba(255, 255, 255, 0.78) !important;
    backdrop-filter: blur(16rpx) contrast(1.12) brightness(1.03) saturate(1.08);
    -webkit-backdrop-filter: blur(16rpx) contrast(1.12) brightness(1.03) saturate(1.08);
  }

  /* Account Detail hero readability final override */
  .detail-hero-title {
    color: #2f271d !important;
  }

  .detail-hero-subtitle,
  .detail-hero-label,
  .detail-hero-note,
  .detail-security-subtitle {
    color: #6f6254 !important;
  }

  .detail-hero-value,
  .detail-security-title {
    color: #3a3026 !important;
  }

  .detail-hero-metric {
    background: linear-gradient(160deg, rgba(255, 255, 255, 0.82), rgba(246, 240, 233, 0.62)) !important;
    border: 1rpx solid rgba(255, 255, 255, 0.7) !important;
  }

  .detail-hero-btn {
    background: linear-gradient(150deg, rgba(255, 255, 255, 0.84), rgba(245, 238, 230, 0.66)) !important;
    border: 1rpx solid rgba(255, 255, 255, 0.72) !important;
    color: #63513d !important;
  }

  .detail-hero-btn-primary {
    background: linear-gradient(140deg, #7a6348, #5f4d39) !important;
    border-color: rgba(255, 255, 255, 0.42) !important;
    color: #fff8ef !important;
  }

  .detail-eye-toggle {
    background: rgba(255, 255, 255, 0.62) !important;
    border-color: rgba(255, 255, 255, 0.78) !important;
  }

  .detail-eye {
    border-color: #675340 !important;
  }

  .detail-eye-pupil,
  .detail-eye-strike {
    background: #675340 !important;
  }

  .detail-security-mini {
    background: rgba(255, 255, 255, 0.8) !important;
    border-color: rgba(255, 255, 255, 0.76) !important;
    color: #63513d !important;
  }

  .detail-security-mini-active {
    background: linear-gradient(140deg, #7a6348, #5f4d39) !important;
    border-color: rgba(255, 255, 255, 0.42) !important;
    color: #fff8ef !important;
  }

  /* Final mobile beauty tuning */
  @media (max-width: 420px) {
    .container {
      padding: 0 18rpx 34rpx !important;
    }

    .card {
      margin-bottom: 16rpx !important;
      padding: 24rpx !important;
      border-radius: 24rpx !important;
      box-shadow: 0 8rpx 18rpx rgba(58, 47, 34, 0.1) !important;
    }

    .detail-hero.card {
      margin-top: 12rpx !important;
      padding: 24rpx 22rpx !important;
      border-radius: 30rpx !important;
      background: linear-gradient(160deg, rgba(255, 255, 255, 0.9), rgba(244, 236, 226, 0.64)) !important;
    }

    .detail-hero-top {
      display: flex !important;
      flex-direction: row !important;
      align-items: flex-start !important;
      gap: 12rpx !important;
    }

    .detail-hero-title {
      font-size: 52rpx !important;
      line-height: 1.16 !important;
      letter-spacing: 0.3rpx;
    }

    .detail-hero-subtitle {
      margin-top: 8rpx !important;
      font-size: 24rpx !important;
      line-height: 1.56 !important;
    }

    .detail-eye-toggle {
      width: 60rpx !important;
      height: 60rpx !important;
      border-radius: 18rpx !important;
      flex-shrink: 0;
    }

    .detail-hero-metrics {
      display: grid !important;
      grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
      gap: 10rpx !important;
      margin-top: 16rpx !important;
    }

    .detail-hero-metric {
      min-height: 132rpx;
      padding: 14rpx 16rpx !important;
      border-radius: 16rpx !important;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .detail-hero-metric:last-child {
      grid-column: 1 / -1;
      min-height: 118rpx;
    }

    .detail-hero-label {
      font-size: 21rpx !important;
    }

    .detail-hero-value {
      margin-top: 6rpx !important;
      font-size: 38rpx !important;
      line-height: 1.2 !important;
    }

    .detail-hero-note {
      margin-top: 5rpx !important;
      font-size: 22rpx !important;
      line-height: 1.4;
    }

    .detail-hero-actions {
      display: grid !important;
      grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
      gap: 10rpx !important;
      margin-top: 16rpx !important;
    }

    .detail-hero-btn {
      width: 100% !important;
      min-width: 0;
      height: 64rpx !important;
      line-height: 64rpx !important;
      font-size: 24rpx !important;
      border-radius: 16rpx !important;
    }

    .detail-hero-btn-primary {
      grid-column: 1 / -1;
      height: 70rpx !important;
      line-height: 70rpx !important;
    }

    .detail-hero-foot {
      margin-top: 14rpx !important;
      padding-top: 12rpx !important;
      display: flex !important;
      flex-direction: row !important;
      align-items: flex-end !important;
      justify-content: space-between !important;
    }

    .detail-security-title {
      font-size: 30rpx !important;
    }

    .detail-security-subtitle {
      font-size: 22rpx !important;
      line-height: 1.46 !important;
    }

    .detail-security-mini {
      height: 56rpx;
      line-height: 56rpx;
      padding: 0 18rpx !important;
      border-radius: 999rpx !important;
      font-size: 22rpx !important;
    }

    .detail-risk-grid,
    .outlook-grid {
      display: grid !important;
      grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
      gap: 10rpx !important;
    }

    .list-title {
      padding: 0 !important;
      margin-bottom: 8rpx !important;
    }

    .chart-box {
      padding: 12rpx 0 !important;
    }

    .swiper-container {
      height: 540rpx !important;
    }
  }

  @media (max-width: 360px) {
    .detail-hero-title {
      font-size: 46rpx !important;
    }

    .detail-risk-grid,
    .outlook-grid {
      grid-template-columns: 1fr !important;
    }
  }