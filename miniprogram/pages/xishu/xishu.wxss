.ys-page {
  min-height: 100vh;
  background:
    radial-gradient(circle at 14% -8%, rgba(148, 163, 184, 0.16) 0%, rgba(148, 163, 184, 0) 34%),
    radial-gradient(circle at 86% 0%, rgba(147, 197, 253, 0.18) 0%, rgba(147, 197, 253, 0) 30%),
    linear-gradient(170deg, #f7faff 0%, #edf2f8 70%, #e9eef6 100%);
  padding-bottom: 260rpx;
  position: relative;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
}

.hero-bg {
  padding: 20rpx 24rpx 20rpx;
  background: linear-gradient(160deg, #edf4ff 0%, #e1ebf8 100%);
  border-bottom-left-radius: 36rpx;
  border-bottom-right-radius: 36rpx;
}

.overview-card {
  margin-top: 0;
  background: linear-gradient(150deg, rgba(255, 255, 255, 0.86), rgba(255, 255, 255, 0.68));
  border: 1rpx solid rgba(214, 226, 241, 0.78);
  backdrop-filter: blur(16rpx) saturate(1.15);
  -webkit-backdrop-filter: blur(16rpx) saturate(1.15);
  border-radius: 28rpx;
  padding: 26rpx 26rpx 20rpx;
  box-shadow: 0 14rpx 34rpx rgba(30, 41, 59, 0.09);
}

.overview-header {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.overview-title {
  font-size: 38rpx;
  line-height: 1;
  font-weight: 700;
  color: #161a26;
}

.overview-badge {
  height: 40rpx;
  min-width: 70rpx;
  border-radius: 999rpx;
  padding: 0 16rpx;
  background: #e8eef8;
  color: #405672;
  font-size: 26rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.overview-main {
  margin-top: 24rpx;
  display: flex;
}

.overview-cell {
  flex: 1;
}

.overview-cell.right {
  padding-left: 18rpx;
}

.overview-label {
  display: block;
  font-size: 26rpx;
  line-height: 1;
  color: #1b1f2b;
  margin-bottom: 16rpx;
}

.overview-value {
  font-size: 52rpx;
  line-height: 1;
  font-weight: 700;
  color: #141823;
}

.overview-divider {
  margin: 24rpx 0 18rpx;
  border-top: 1rpx dashed #e6e7ee;
}

.status-row {
  display: flex;
  gap: 20rpx;
}

.status-item {
  flex: 1;
}

.status-text {
  display: block;
  font-size: 24rpx;
  color: #7e818d;
  margin-bottom: 14rpx;
}

.status-track {
  height: 16rpx;
  border-radius: 999rpx;
  background: #eef0f4;
  overflow: hidden;
}

.status-fill {
  height: 100%;
  background: linear-gradient(90deg, #5b7597 0%, #34465f 100%);
}

.filter-row {
  margin-top: 18rpx;
  padding: 0 24rpx;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.type-switch {
  width: 100%;
  display: inline-flex;
  background: #e6edf7;
  border-radius: 999rpx;
  padding: 6rpx;
  box-sizing: border-box;
}

.type-chip {
  flex: 1;
  height: 56rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #6f7483;
}

.type-chip.active {
  background: #ffffff;
  color: #2f4664;
  font-weight: 600;
}

.filter-scroll {
  width: calc(100% - 200rpx);
  white-space: nowrap;
}

.filter-scroll-inner {
  display: inline-flex;
  gap: 12rpx;
}

.filter-chip {
  height: 62rpx;
  border-radius: 999rpx;
  padding: 0 24rpx;
  background: #f0f4fa;
  color: #5f6f84;
  font-size: 24rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.filter-chip.active {
  background: linear-gradient(140deg, #3d5778, #253754);
  color: #ffffff;
}

.filter-icons {
  width: 186rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  color: #222633;
  justify-content: flex-end;
}

.small-icon {
  font-size: 26rpx;
  font-weight: 700;
}

.small-icon.active {
  color: #2f4664;
}

.search-row {
  margin: 10rpx 24rpx 0;
}

.sync-tip {
  margin: 10rpx 24rpx 0;
  font-size: 22rpx;
  color: #8d93a1;
}

.sync-tip.syncing {
  color: #6f7483;
}

.sync-tip.synced {
  color: #1f2430;
}

.sync-tip.failed {
  color: #d84444;
}

.viz-card {
  margin: 12rpx 24rpx 0;
  padding: 18rpx 18rpx 16rpx;
  border-radius: 20rpx;
  background: #ffffff;
}

.viz-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.viz-title {
  font-size: 28rpx;
  color: #161a26;
  font-weight: 600;
}

.viz-sub {
  font-size: 22rpx;
  color: #8b90a0;
}

.viz-list {
  margin-top: 10rpx;
}

.viz-item {
  margin-top: 12rpx;
}

.viz-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.viz-name {
  font-size: 24rpx;
  color: #2a3040;
}

.viz-value {
  font-size: 22rpx;
  color: #6f7483;
}

.viz-track {
  margin-top: 8rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: #edf0f6;
  overflow: hidden;
}

.viz-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #88a8ce 0%, #324a68 100%);
}

.search-input {
  width: 100%;
  height: 64rpx;
  border-radius: 999rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.66);
  border: 1rpx solid rgba(255, 255, 255, 0.58);
  backdrop-filter: blur(12rpx);
  -webkit-backdrop-filter: blur(12rpx);
  padding: 0 24rpx;
  color: #1f2430;
  font-size: 22rpx;
}

.asset-list {
  margin: 16rpx 24rpx 0;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.asset-item {
  border-radius: 18rpx;
  background: linear-gradient(155deg, rgba(255, 255, 255, 0.76), rgba(255, 255, 255, 0.56));
  border: 1rpx solid rgba(255, 255, 255, 0.55);
  backdrop-filter: blur(12rpx) saturate(1.12);
  -webkit-backdrop-filter: blur(12rpx) saturate(1.12);
  padding: 16rpx;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.08);
}

.asset-icon-wrap {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.asset-icon-box {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  overflow: hidden;
  background: #f5f6fa;
  display: flex;
  align-items: center;
  justify-content: center;
}

.asset-icon {
  font-size: 46rpx;
}

.asset-icon-image {
  width: 100%;
  height: 100%;
}

.asset-name {
  margin-top: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #181c27;
}

.asset-badge {
  height: 44rpx;
  border-radius: 999rpx;
  background: #f0f1f5;
  padding: 0 14rpx;
  display: inline-flex;
  align-items: center;
  font-size: 20rpx;
  color: #22242f;
}

.asset-line {
  margin-top: 6rpx;
  color: #989eab;
  font-size: 20rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.asset-line.minor {
  margin-top: 4rpx;
  color: #6f7483;
}

.asset-dust-row {
  margin-top: 10rpx;
}

.asset-dust-label {
  font-size: 20rpx;
  color: #4e5563;
}

.asset-dust-track {
  margin-top: 6rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: rgba(17, 24, 39, 0.08);
  overflow: hidden;
}

.asset-dust-fill {
  height: 100%;
  border-radius: 999rpx;
}

.asset-dust-fill.progress-red {
  background: linear-gradient(90deg, #f58c8c 0%, #d84444 100%);
}

.asset-dust-fill.progress-yellow {
  background: linear-gradient(90deg, #f4cf75 0%, #e1a53b 100%);
}

.asset-dust-fill.progress-green {
  background: linear-gradient(90deg, #a8dfbb 0%, #3fa469 100%);
}

.asset-bottom {
  margin-top: 18rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.asset-checkin-tip {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #5f7da5;
}

.asset-daily {
  font-size: 34rpx;
  font-weight: 700;
  color: #151924;
}

.asset-delete {
  width: 86rpx;
  height: 38rpx;
  border: 1rpx solid #f1c7c7;
  border-radius: 999rpx;
  color: #d84444;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-area {
  margin-top: 240rpx;
  text-align: center;
  color: #b3b6c0;
}

.empty-icon {
  font-size: 80rpx;
}

.empty-title {
  display: block;
  margin-top: 12rpx;
  font-size: 38rpx;
  color: #2e323f;
  font-weight: 600;
}

.empty-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #959aa8;
}

.bottom-dock {
  position: fixed;
  right: 24rpx;
  left: auto;
  bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  z-index: 20;
}

.dock-plus {
  width: 98rpx;
  height: 98rpx;
  border-radius: 50%;
  background: linear-gradient(140deg, #3d5778, #253754);
  color: #ffffff;
  font-size: 56rpx;
  line-height: 98rpx;
  text-align: center;
  box-shadow: 0 14rpx 28rpx rgba(37, 55, 84, 0.28);
}

.detail-page {
  position: fixed;
  inset: 0;
  background:
    radial-gradient(circle at 20% -10%, rgba(147, 197, 253, 0.2) 0%, rgba(147, 197, 253, 0) 32%),
    linear-gradient(165deg, #f8fbff 0%, #eef3f9 68%, #e9eff7 100%);
  z-index: 34;
  overflow-y: auto;
  padding: 20rpx 24rpx calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.detail-top {
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.detail-close,
.detail-edit {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  color: #1a1e2a;
}

.detail-hero {
  margin-top: 16rpx;
  text-align: center;
}

.detail-icon-wrap {
  margin: 0 auto;
  width: 136rpx;
  height: 136rpx;
  border-radius: 34rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.detail-icon-image {
  width: 100%;
  height: 100%;
}

.detail-icon {
  font-size: 72rpx;
}

.detail-name {
  display: block;
  margin-top: 18rpx;
  font-size: 52rpx;
  font-weight: 600;
  color: #171b26;
}

.detail-daily {
  display: block;
  margin-top: 10rpx;
  font-size: 66rpx;
  font-weight: 700;
  color: #171b26;
}

.detail-meta {
  display: block;
  margin-top: 8rpx;
  font-size: 30rpx;
  color: #8a90a0;
}

.detail-use-btn {
  margin-top: 16rpx;
  min-width: 220rpx;
  height: 60rpx;
  border-radius: 999rpx;
  padding: 0 24rpx;
  background: linear-gradient(140deg, #3d5778, #253754);
  color: #ffffff;
  font-size: 24rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.detail-hero-actions {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.detail-edit-btn {
  min-width: 196rpx;
  height: 60rpx;
  border-radius: 999rpx;
  padding: 0 22rpx;
  background: linear-gradient(140deg, rgba(255, 255, 255, 0.94), rgba(243, 247, 255, 0.86));
  border: 1rpx solid rgba(125, 142, 172, 0.36);
  color: #2f425f;
  font-size: 24rpx;
  font-weight: 600;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.detail-hero-actions .detail-use-btn {
  margin-top: 0;
}

.detail-chart-card,
.detail-quantile-card,
.detail-info-card {
  margin-top: 22rpx;
  background: linear-gradient(155deg, rgba(255, 255, 255, 0.78), rgba(255, 255, 255, 0.58));
  border: 1rpx solid rgba(255, 255, 255, 0.56);
  backdrop-filter: blur(14rpx);
  -webkit-backdrop-filter: blur(14rpx);
  border-radius: 28rpx;
  padding: 22rpx;
  box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.1);
}

.detail-dual-card,
.detail-dust-card {
  margin-top: 22rpx;
  background: linear-gradient(155deg, rgba(255, 255, 255, 0.78), rgba(255, 255, 255, 0.58));
  border: 1rpx solid rgba(255, 255, 255, 0.56);
  backdrop-filter: blur(14rpx);
  -webkit-backdrop-filter: blur(14rpx);
  border-radius: 28rpx;
  padding: 22rpx;
  box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.1);
}

.detail-dual-head,
.detail-dust-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.detail-dual-title,
.detail-dust-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1e2a;
}

.detail-dual-sub,
.detail-dust-tag {
  font-size: 22rpx;
  color: #718096;
}

.detail-dual-grid {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.detail-dual-modes {
  margin-top: 14rpx;
  display: flex;
  gap: 10rpx;
}

.detail-dual-mode {
  min-width: 110rpx;
  height: 50rpx;
  border-radius: 999rpx;
  padding: 0 18rpx;
  background: rgba(255, 255, 255, 0.7);
  border: 1rpx solid rgba(148, 158, 175, 0.3);
  color: #5d6677;
  font-size: 24rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.detail-dual-mode.active {
  background: linear-gradient(120deg, rgba(122, 159, 204, 0.24), rgba(122, 159, 204, 0.1));
  border-color: rgba(91, 117, 151, 0.46);
  color: #355072;
  font-weight: 600;
}

.detail-dual-cell,
.detail-dust-cell {
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.7);
  border: 1rpx solid rgba(236, 239, 245, 0.9);
  padding: 14rpx;
}

.detail-dual-key,
.detail-dust-key {
  display: block;
  font-size: 22rpx;
  color: #8a90a0;
}

.detail-dual-value,
.detail-dust-value {
  display: block;
  margin-top: 8rpx;
  font-size: 28rpx;
  color: #202534;
  font-weight: 700;
}

.detail-dual-summary,
.detail-dust-summary {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #62707f;
  line-height: 1.5;
}

.detail-dual-primary {
  margin-top: 14rpx;
  min-height: 74rpx;
  border-radius: 16rpx;
  background: rgba(15, 23, 42, 0.06);
  padding: 0 14rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.detail-dual-primary-label {
  font-size: 22rpx;
  color: #5f6674;
}

.detail-dual-primary-value {
  font-size: 30rpx;
  color: #1f2432;
  font-weight: 700;
}

.detail-dust-score {
  margin-top: 12rpx;
  font-size: 52rpx;
  line-height: 1;
  font-weight: 800;
  color: #e65a44;
}

.detail-dust-track {
  margin-top: 12rpx;
  height: 16rpx;
  border-radius: 999rpx;
  background: rgba(17, 24, 39, 0.08);
  overflow: hidden;
}

.detail-dust-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #ffc46f 0%, #e05353 100%);
}

.detail-dust-grid {
  margin-top: 14rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.detail-card-title {
  font-size: 42rpx;
  font-weight: 600;
  color: #171b26;
  margin-bottom: 12rpx;
}

.detail-chart-card ec-canvas {
  display: block;
  width: 100%;
  height: 380rpx;
}

.detail-quantile-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.detail-quantile-head-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.detail-quantile-title {
  font-size: 34rpx;
  color: #1a1e2a;
  font-weight: 600;
}

.detail-quantile-spec-btn {
  height: 44rpx;
  border-radius: 999rpx;
  padding: 0 14rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(145, 154, 170, 0.35);
  color: #5a6270;
  font-size: 22rpx;
  display: inline-flex;
  align-items: center;
}

.detail-quantile-tag {
  height: 46rpx;
  border-radius: 999rpx;
  padding: 0 16rpx;
  background: linear-gradient(120deg, rgba(132, 216, 22, 0.18), rgba(132, 216, 22, 0.06));
  color: #436a10;
  font-size: 24rpx;
  display: inline-flex;
  align-items: center;
}

.detail-quantile-track {
  margin-top: 18rpx;
  width: 100%;
  height: 20rpx;
  border-radius: 999rpx;
  background: #edf1f7;
  overflow: hidden;
}

.detail-quantile-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #8fcf22 0%, #3f7410 100%);
}

.detail-quantile-foot {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.detail-quantile-level {
  font-size: 30rpx;
  color: #232836;
  font-weight: 600;
}

.detail-quantile-sample {
  font-size: 24rpx;
  color: #8a90a0;
}

.detail-quantile-empty-title {
  display: block;
  margin-top: 18rpx;
  font-size: 30rpx;
  color: #232836;
  font-weight: 600;
}

.detail-quantile-hint {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #7f8796;
  line-height: 1.5;
}

.detail-projection-card {
  margin-top: 22rpx;
  background: linear-gradient(155deg, rgba(255, 255, 255, 0.78), rgba(255, 255, 255, 0.58));
  border: 1rpx solid rgba(255, 255, 255, 0.56);
  backdrop-filter: blur(14rpx);
  -webkit-backdrop-filter: blur(14rpx);
  border-radius: 28rpx;
  padding: 22rpx;
  box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.1);
}

.detail-projection-head {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.detail-projection-title {
  font-size: 34rpx;
  color: #1a1e2a;
  font-weight: 600;
}

.detail-projection-summary {
  font-size: 24rpx;
  color: #6a7282;
  line-height: 1.5;
}

.detail-projection-options {
  margin-top: 14rpx;
  display: flex;
  gap: 10rpx;
}

.detail-projection-option {
  min-width: 92rpx;
  height: 50rpx;
  border-radius: 999rpx;
  padding: 0 16rpx;
  background: rgba(255, 255, 255, 0.65);
  border: 1rpx solid rgba(148, 158, 175, 0.3);
  color: #60697a;
  font-size: 24rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.detail-projection-option.active {
  background: linear-gradient(120deg, rgba(132, 216, 22, 0.2), rgba(132, 216, 22, 0.08));
  border-color: rgba(132, 216, 22, 0.48);
  color: #3f6a0f;
  font-weight: 600;
}

.detail-projection-grid {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.detail-projection-cell {
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(236, 239, 245, 0.9);
  padding: 14rpx;
}

.detail-projection-key {
  display: block;
  font-size: 22rpx;
  color: #8a90a0;
}

.detail-projection-value {
  display: block;
  margin-top: 8rpx;
  font-size: 27rpx;
  color: #202534;
  font-weight: 600;
}

.detail-projection-sub {
  display: block;
  margin-top: 6rpx;
  font-size: 20rpx;
  color: #8a90a0;
}

.detail-projection-target {
