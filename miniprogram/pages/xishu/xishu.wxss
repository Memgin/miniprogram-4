.ys-page {
  min-height: 100vh;
  background: #efeff5;
  padding-bottom: 260rpx;
  position: relative;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
}

.hero-bg {
  padding: 20rpx 24rpx 20rpx;
  background: linear-gradient(160deg, #acf348 0%, #d7f88d 100%);
  border-bottom-left-radius: 36rpx;
  border-bottom-right-radius: 36rpx;
}

.overview-card {
  margin-top: 0;
  background: #ffffff;
  border-radius: 28rpx;
  padding: 26rpx 26rpx 20rpx;
}

.overview-header {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.overview-title {
  font-size: 38rpx;
  line-height: 1;
  font-weight: 700;
  color: #161a26;
}

.overview-badge {
  height: 40rpx;
  min-width: 70rpx;
  border-radius: 999rpx;
  padding: 0 16rpx;
  background: #eff0f4;
  color: #3b3f4b;
  font-size: 26rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.overview-main {
  margin-top: 24rpx;
  display: flex;
}

.overview-cell {
  flex: 1;
}

.overview-cell.right {
  padding-left: 18rpx;
}

.overview-label {
  display: block;
  font-size: 26rpx;
  line-height: 1;
  color: #1b1f2b;
  margin-bottom: 16rpx;
}

.overview-value {
  font-size: 52rpx;
  line-height: 1;
  font-weight: 700;
  color: #141823;
}

.overview-divider {
  margin: 24rpx 0 18rpx;
  border-top: 1rpx dashed #e6e7ee;
}

.status-row {
  display: flex;
  gap: 20rpx;
}

.status-item {
  flex: 1;
}

.status-text {
  display: block;
  font-size: 24rpx;
  color: #7e818d;
  margin-bottom: 14rpx;
}

.status-track {
  height: 16rpx;
  border-radius: 999rpx;
  background: #eef0f4;
  overflow: hidden;
}

.status-fill {
  height: 100%;
  background: #11131d;
}

.filter-row {
  margin-top: 18rpx;
  padding: 0 24rpx;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.type-switch {
  width: 100%;
  display: inline-flex;
  background: #e8ebf2;
  border-radius: 999rpx;
  padding: 6rpx;
  box-sizing: border-box;
}

.type-chip {
  flex: 1;
  height: 56rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #6f7483;
}

.type-chip.active {
  background: #ffffff;
  color: #1a1e2a;
  font-weight: 600;
}

.filter-scroll {
  width: calc(100% - 200rpx);
  white-space: nowrap;
}

.filter-scroll-inner {
  display: inline-flex;
  gap: 12rpx;
}

.filter-chip {
  height: 62rpx;
  border-radius: 999rpx;
  padding: 0 24rpx;
  background: #f4f5f9;
  color: #666a74;
  font-size: 24rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.filter-chip.active {
  background: #11131d;
  color: #ffffff;
}

.filter-icons {
  width: 186rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  color: #222633;
  justify-content: flex-end;
}

.small-icon {
  font-size: 26rpx;
  font-weight: 700;
}

.small-icon.active {
  color: #11131d;
}

.search-row {
  margin: 10rpx 24rpx 0;
}

.search-input {
  width: 100%;
  height: 64rpx;
  border-radius: 999rpx;
  box-sizing: border-box;
  background: #ffffff;
  padding: 0 24rpx;
  color: #1f2430;
  font-size: 22rpx;
}

.asset-list {
  margin: 16rpx 24rpx 0;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.asset-item {
  border-radius: 18rpx;
  background: #ffffff;
  padding: 16rpx;
}

.asset-icon-wrap {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.asset-icon-box {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  overflow: hidden;
  background: #f5f6fa;
  display: flex;
  align-items: center;
  justify-content: center;
}

.asset-icon {
  font-size: 46rpx;
}

.asset-icon-image {
  width: 100%;
  height: 100%;
}

.asset-name {
  margin-top: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #181c27;
}

.asset-badge {
  height: 44rpx;
  border-radius: 999rpx;
  background: #f0f1f5;
  padding: 0 14rpx;
  display: inline-flex;
  align-items: center;
  font-size: 20rpx;
  color: #22242f;
}

.asset-line {
  margin-top: 6rpx;
  color: #989eab;
  font-size: 20rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.asset-bottom {
  margin-top: 18rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.asset-daily {
  font-size: 34rpx;
  font-weight: 700;
  color: #151924;
}

.asset-delete {
  width: 86rpx;
  height: 38rpx;
  border: 1rpx solid #f1c7c7;
  border-radius: 999rpx;
  color: #d84444;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-area {
  margin-top: 240rpx;
  text-align: center;
  color: #b3b6c0;
}

.empty-icon {
  font-size: 80rpx;
}

.empty-title {
  display: block;
  margin-top: 12rpx;
  font-size: 38rpx;
  color: #2e323f;
  font-weight: 600;
}

.empty-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #959aa8;
}

.bottom-dock {
  position: fixed;
  right: 24rpx;
  left: auto;
  bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  z-index: 20;
}

.dock-plus {
  width: 98rpx;
  height: 98rpx;
  border-radius: 50%;
  background: #11131d;
  color: #ffffff;
  font-size: 56rpx;
  line-height: 98rpx;
  text-align: center;
}

.editor-page {
  position: fixed;
  inset: 0;
  background: #efeff5;
  z-index: 35;
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
}

.editor-top {
  position: relative;
  padding: 22rpx 24rpx 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.editor-close {
  position: absolute;
  left: 16rpx;
  top: 10rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  font-size: 40rpx;
  color: #191d2a;
  display: flex;
  align-items: center;
  justify-content: center;
}

.editor-tabs {
  display: flex;
  gap: 44rpx;
  transition: transform 0.2s ease;
}

.editor-tabs.asset-active {
  transform: translateX(62rpx);
}

.editor-tabs.wish-active {
  transform: translateX(-62rpx);
}

.editor-tab {
  font-size: 40rpx;
  color: #a4a8b2;
  position: relative;
}

.editor-tab.active {
  color: #161a25;
  font-weight: 600;
}

.editor-tab.active::after {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  bottom: -10rpx;
  margin: auto;
  width: 72rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: #b8ff1d;
}

.editor-scroll {
  flex: 1;
  height: calc(100vh - 108rpx);
  padding: 0;
  box-sizing: border-box;
}

.editor-scroll-inner {
  padding: 0 24rpx;
  box-sizing: border-box;
  padding-bottom: calc(96rpx + env(safe-area-inset-bottom));
}

.ocr-card {
  margin: 32rpx auto 0;
  padding: 24rpx 32rpx;
  background: linear-gradient(135deg, #f4f8ff 0%, #e0edff 100%);
  border-radius: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 82, 217, 0.08);
  border: 1px solid rgba(0, 82, 217, 0.1);
}

.ocr-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.ocr-icon {
  font-size: 40rpx;
}

.ocr-text {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.ocr-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #0f172a;
}

.ocr-desc {
  font-size: 22rpx;
  color: #64748b;
}

.ocr-btn {
  background: #0052d9;
  color: #ffffff;
  padding: 10rpx 24rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 8rpx rgba(0, 82, 217, 0.3);
}

.editor-avatar-wrap {
  margin: 44rpx auto 0;
  width: 122rpx;
  height: 122rpx;
  position: relative;
}

.editor-avatar {
  width: 110rpx;
  height: 110rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.06);
  font-size: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.icon-edit-fab {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: #ffffff;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.15);
  border: 1rpx solid #e6e8ef;
  color: #2c3342;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.editor-avatar-image {
  width: 100%;
  height: 100%;
}

.editor-name {
  margin: 28rpx auto 0;
  width: 100%;
  height: 76rpx;
  text-align: center;
  font-size: 36rpx;
  color: #1d212d;
}

.editor-card {
  margin-top: 16rpx;
  background: #ffffff;
  border-radius: 28rpx;
  padding: 10rpx 0;
}

.editor-card.single-line {
  padding: 0;
}

.editor-cell {
  min-height: 86rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 26rpx;
}

.editor-cell.last {
  padding-bottom: 10rpx;
}

.cell-left {
  font-size: 30rpx;
  color: #1a1e2a;
  font-weight: 600;
}

.cell-right {
  font-size: 30rpx;
  color: #252a37;
}

.cell-right-input {
  width: 56%;
  text-align: right;
  font-size: 30rpx;
  color: #252a37;
}

.editor-title {
  padding: 0 26rpx;
  font-size: 30rpx;
  color: #1a1e2a;
  font-weight: 600;
}

.cost-mode-wrap {
  margin: 16rpx 16rpx 8rpx;
  border-radius: 999rpx;
  padding: 8rpx;
  background: #f0f1f6;
  display: flex;
  gap: 8rpx;
}

.cost-chip {
  flex: 1;
  height: 64rpx;
  border-radius: 999rpx;
  color: #797f8e;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cost-chip.active {
  background: #ffffff;
  color: #1a1e2a;
}

.note-input {
  height: 80rpx;
  padding: 0 26rpx;
  font-size: 26rpx;
}

.note-media-slot {
  margin: 10rpx 24rpx 20rpx;
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  background: #f3f4f8;
  color: #8e95a3;
  font-size: 46rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.note-media-row {
  display: flex;
  align-items: flex-end;
  gap: 16rpx;
}

.note-media-preview {
  position: relative;
  margin-bottom: 20rpx;
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.note-media-image {
  width: 100%;
  height: 100%;
}

.note-media-remove {
  position: absolute;
  right: 6rpx;
  top: 6rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.56);
  color: #ffffff;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.related-draft-row {
  display: flex;
  gap: 12rpx;
  padding: 14rpx 20rpx 0;
}

.related-input {
  height: 72rpx;
  border-radius: 14rpx;
  background: #f3f4f8;
  text-align: center;
  font-size: 22rpx;
  color: #2a3040;
}

.related-input.name {
  flex: 1.2;
}

.related-input.qty,
.related-input.price {
  flex: 0.8;
}

.add-related {
  margin: 12rpx 20rpx 12rpx;
  height: 90rpx;
  border-radius: 999rpx;
  background: #f3f4f8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
}

.related-list {
  margin: 4rpx 20rpx 16rpx;
  border-radius: 14rpx;
  background: #f8f9fc;
  overflow: hidden;
}

.related-item {
  min-height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 16rpx;
  border-bottom: 1rpx solid #eceff5;
}

.related-item:last-child {
  border-bottom: none;
}

.related-name {
  font-size: 22rpx;
  color: #2a3040;
}

.related-right {
  display: inline-flex;
  align-items: center;
  gap: 14rpx;
}

.related-amount {
  font-size: 22rpx;
  color: #1d2230;
}

.related-remove {
  font-size: 20rpx;
  color: #d84444;
}

.related-total {
  padding: 14rpx 16rpx;
  font-size: 22rpx;
  color: #495166;
  background: #f3f5fa;
  text-align: right;
}

.toggle-row {
  min-height: 96rpx;
  padding: 0 26rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 30rpx;
  color: #1a1e2a;
}

.toggle-label {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
}

.row-icon {
  width: 34rpx;
  text-align: center;
  font-size: 28rpx;
  color: #2b3140;
}

.row-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 30rpx;
  height: 30rpx;
  border-radius: 8rpx;
  font-size: 18rpx;
  color: #1d2a0f;
  background: #b8ff1d;
  margin-left: 4rpx;
}

.save-btn {
  margin: 20rpx auto 0;
  width: 74%;
  height: 86rpx;
  border-radius: 999rpx;
  background: #11131d;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-library-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.25);
  z-index: 80;
}

.icon-library-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 68vh;
  background: #ffffff;
  border-top-left-radius: 28rpx;
  border-top-right-radius: 28rpx;
  z-index: 81;
  display: flex;
  flex-direction: column;
}

.icon-library-head {
  height: 88rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #f0f2f7;
}

.icon-library-head.compact {
  height: 96rpx;
  border-bottom: none;
}

.icon-head-action {
  font-size: 34rpx;
  color: #111827;
  min-width: 92rpx;
}

.icon-head-action.strong {
  font-weight: 700;
  text-align: right;
}

.icon-mode-tabs {
  display: inline-flex;
  align-items: center;
  background: #f2f3f7;
  border-radius: 20rpx;
  padding: 6rpx;
  gap: 4rpx;
}

.icon-mode-tab {
  min-width: 112rpx;
  height: 58rpx;
  border-radius: 16rpx;
  font-size: 34rpx;
  color: #5b6170;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-mode-tab.active {
  background: #ffffff;
  color: #111827;
  font-weight: 600;
}

.icon-selected-preview {
  padding: 4rpx 0 6rpx;
  display: flex;
  justify-content: center;
}

.icon-selected-thumb-wrap {
  width: 90rpx;
  height: 90rpx;
  border-radius: 16rpx;
  background: #f4f6fb;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.icon-selected-thumb {
  width: 72rpx;
  height: 72rpx;
}

.icon-selected-emoji {
  font-size: 54rpx;
}

.emoji-grid-wrap {
  flex: 1;
  overflow: hidden;
  padding: 12rpx 18rpx calc(18rpx + env(safe-area-inset-bottom));
}

.emoji-grid {
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 12rpx;
}

.emoji-grid-item {
  height: 88rpx;
  border-radius: 16rpx;
  background: #f4f6fb;
  font-size: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.emoji-grid-item.active {
  background: #11131d;
}

.icon-album-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
}

.icon-album-btn {
  height: 78rpx;
  border-radius: 999rpx;
  padding: 0 36rpx;
  background: #11131d;
  color: #ffffff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-library-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.icon-library-close {
  font-size: 32rpx;
  color: #6b7280;
}

.icon-category-scroll {
  width: 100%;
  white-space: nowrap;
  border-bottom: 1rpx solid #f2f4f8;
}

.icon-category-row {
  display: inline-flex;
  gap: 10rpx;
  padding: 14rpx 20rpx;
}

.icon-category-chip {
  min-width: 92rpx;
  height: 52rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #f4f5f9;
  color: #4b5563;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-category-chip.active {
  background: #11131d;
  color: #ffffff;
}

.icon-library-loading {
  padding-top: 40rpx;
  text-align: center;
  color: #6b7280;
  font-size: 24rpx;
}

.icon-library-search-row {
  padding: 12rpx 18rpx 8rpx;
}

.icon-library-search-input {
  height: 62rpx;
  border-radius: 999rpx;
  background: #f4f6fb;
  padding: 0 22rpx;
  font-size: 24rpx;
  color: #1f2937;
}

.icon-grid-scroll {
  flex: 1;
  min-height: 0;
}

.icon-grid {
  padding: 18rpx 18rpx calc(18rpx + env(safe-area-inset-bottom));
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 14rpx;
}

.icon-grid-item {
  background: #f4f5f9;
  border-radius: 16rpx;
  padding: 12rpx 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.icon-grid-thumb-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 14rpx;
  background: #eef1f7;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-grid-thumb {
  width: 58rpx;
  height: 58rpx;
}

.icon-grid-name {
  font-size: 20rpx;
  color: #4b5563;
  max-width: 100%;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.icon-grid-footer,
.icon-grid-empty {
  grid-column: 1 / -1;
  text-align: center;
  color: #9aa1af;
  font-size: 22rpx;
  padding: 8rpx 0 20rpx;
}

