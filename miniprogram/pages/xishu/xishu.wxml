<view class="ys-page">
  <view class="custom-nav" style="height: {{navTotalHeight}}px; padding-top: {{navStatusHeight}}px;">
    <view class="custom-nav-inner" style="height: {{navContentHeight}}px;">
      <view class="custom-nav-side" style="width: {{navCapsuleSpace}}px;"></view>
      <view class="custom-nav-title">{{navTitle}}</view>
      <view class="custom-nav-side" style="width: {{navCapsuleSpace}}px;"></view>
    </view>
  </view>

  <view class="hero-bg">
    <view class="overview-card">
      <view class="overview-header">
        <text class="overview-title">资产总览</text>
        <text class="overview-badge">{{overviewBadge}}</text>
      </view>

      <view class="overview-main">
        <view class="overview-cell">
          <text class="overview-label">总资产</text>
          <text class="overview-value">{{totalAssetText}}</text>
        </view>
        <view class="overview-cell right">
          <text class="overview-label">日均成本</text>
          <text class="overview-value">{{avgDailyCostText}}</text>
        </view>
      </view>

      <view class="overview-divider" wx:if="{{listType === 'asset'}}"></view>

      <view class="status-row" wx:if="{{listType === 'asset'}}">
        <view class="status-item" wx:for="{{statusSummary}}" wx:key="id">
          <text class="status-text">{{item.text}} {{item.count}}</text>
          <view class="status-track">
            <view class="status-fill" style="width: {{item.progress}}%;"></view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="filter-row">
    <view class="type-switch">
      <view class="type-chip {{listType === 'asset' ? 'active' : ''}}" data-type="asset" bindtap="onSwitchListType">资产</view>
      <view class="type-chip {{listType === 'wish' ? 'active' : ''}}" data-type="wish" bindtap="onSwitchListType">心愿</view>
    </view>
    <scroll-view class="filter-scroll" scroll-x="true" enhanced="true" show-scrollbar="false" wx:if="{{listType === 'asset'}}">
      <view class="filter-scroll-inner">
        <view
          class="filter-chip {{activeFilter === item.id ? 'active' : ''}}"
          wx:for="{{filters}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="onFilterTap"
        >
          {{item.text}}
        </view>
      </view>
    </scroll-view>
    <view class="filter-icons" wx:if="{{listType === 'asset'}}">
      <text class="small-icon {{showOnlyPinned ? 'active' : ''}}" data-action="toggle-pinned" bindtap="onToolbarAction">◈</text>
      <text class="small-icon" bindtap="onToggleSort">⇅</text>
    </view>
  </view>

  <view class="search-row">
    <input class="search-input" placeholder="搜索名称或备注" value="{{searchKeyword}}" focus="{{searchFocus}}" bindinput="onSearchInput" bindblur="onSearchBlur" />
  </view>

  <view class="sync-tip {{cloudSyncState}}">
    <text>{{cloudSyncText}}</text>
  </view>

  <view class="viz-card" wx:if="{{categoryVisualList.length}}">
    <view class="viz-head">
      <text class="viz-title">资产分类可视化</text>
      <text class="viz-sub">TOP {{categoryVisualList.length}}</text>
    </view>
    <view class="viz-list">
      <view class="viz-item" wx:for="{{categoryVisualList}}" wx:key="name">
        <view class="viz-row">
          <text class="viz-name">{{item.name}}</text>
          <text class="viz-value">{{item.valueText}} · {{item.ratio}}%</text>
        </view>
        <view class="viz-track">
          <view class="viz-fill" style="width: {{item.width}};"></view>
        </view>
      </view>
    </view>
  </view>

  <view class="asset-list" wx:if="{{viewAssets.length}}">
    <view class="asset-item" wx:for="{{viewAssets}}" wx:key="id" data-id="{{item.id}}" bindtap="onTapAssetCard">
      <view class="asset-icon-wrap">
        <view class="asset-icon-box">
          <image class="asset-icon-image" wx:if="{{item.iconType === 'image' && item.iconImagePath}}" src="{{item.iconImagePath}}" mode="aspectFill" />
          <text class="asset-icon" wx:else>{{item.iconEmoji || (item.type === 'wish' ? '🎯' : '📦')}}</text>
        </view>
        <text class="asset-badge" wx:if="{{item.type === 'asset'}}">● {{item.statusText}}</text>
      </view>
      <text class="asset-name">{{item.name}}</text>
      <view class="asset-line" wx:if="{{item.type === 'asset'}}">
        <text>{{item.effectivePriceText}} | 已使用{{item.holdText}}</text>
      </view>
      <view class="asset-line minor" wx:if="{{item.type === 'asset'}}">
        <text>{{item.modeHintText}}</text>
      </view>
      <view class="asset-dust-row" wx:if="{{item.type === 'asset'}}">
        <text class="asset-dust-label">{{item.progressLabelText}}</text>
        <view class="asset-dust-track">
          <view class="asset-dust-fill {{item.progressFillClass}}" style="width: {{item.progressTrackWidth}};"></view>
        </view>
      </view>
      <view class="asset-bottom">
        <text class="asset-daily">{{item.primaryCostText}}</text>
        <view class="asset-delete" data-id="{{item.id}}" catchtap="onDeleteAsset">删除</view>
      </view>
      <text class="asset-checkin-tip" wx:if="{{item.type === 'asset' && item.costMode === 'use'}}">双击卡片快速打卡 +1</text>
    </view>
  </view>

  <view class="empty-area" wx:if="{{!viewAssets.length}}">
    <view class="empty-icon">📦</view>
    <text class="empty-title">空空如也</text>
    <text class="empty-desc">点击 + 添加{{listType === 'asset' ? '资产' : '心愿'}}</text>
  </view>

  <view class="bottom-dock" wx:if="{{!editorVisible && !detailVisible}}">
    <view class="dock-plus" bindtap="onOpenEditor">+</view>
  </view>

  <view class="detail-page" wx:if="{{detailVisible && detailItem}}" style="padding-top: {{navStatusHeight + 8}}px;">
    <view class="detail-top">
      <view class="detail-close" bindtap="onCloseDetail">✕</view>
      <view class="detail-top-title">详情</view>
    </view>

    <view class="detail-hero">
      <view class="detail-icon-wrap">
        <image class="detail-icon-image" wx:if="{{detailItem.iconType === 'image' && detailItem.iconImagePath}}" src="{{detailItem.iconImagePath}}" mode="aspectFill" />
        <text class="detail-icon" wx:else>{{detailItem.iconEmoji || '📦'}}</text>
      </view>
      <text class="detail-name">{{detailItem.name}}</text>
      <text class="detail-daily">{{detailItem.dailyText}}/天</text>
      <text class="detail-meta">总价 {{detailItem.totalText}} ｜ 已使用 {{detailItem.holdText}}</text>
      <view class="detail-hero-actions">
        <button class="detail-edit-btn" bindtap="onTapDetailEdit">修改信息</button>
        <button class="detail-use-btn" wx:if="{{detailItem.costMode === 'use'}}" bindtap="onTapDetailUseCheckin">+1 使用打卡</button>
      </view>
    </view>

    <view class="detail-chart-card">
      <view class="detail-card-title">日均成本</view>
      <ec-canvas id="xishu-detail-trend-chart" canvas-id="xishu-detail-trend-chart-canvas" ec="{{ecDetailTrend}}" type="2d"></ec-canvas>
    </view>

    <view class="detail-dual-card" wx:if="{{detailItem.usageModel}}">
      <view class="detail-dual-head">
        <text class="detail-dual-title">双轨降本系统</text>
        <text class="detail-dual-sub">按天 / 按次 双视角</text>
      </view>
      <view class="detail-dual-modes">
        <view
          class="detail-dual-mode {{detailItem.usageModel.selectedMode === item.id ? 'active' : ''}}"
          wx:for="{{detailItem.usageModel.modeOptions}}"
          wx:key="id"
          data-mode="{{item.id}}"
          bindtap="onSelectDetailCostMode"
        >{{item.text}}</view>
      </view>
      <view class="detail-dual-grid">
        <view class="detail-dual-cell">
          <text class="detail-dual-key">时间日均成本</text>
          <text class="detail-dual-value">{{detailItem.usageModel.dailyCostText}}/天</text>
        </view>
        <view class="detail-dual-cell">
          <text class="detail-dual-key">单次使用成本</text>
          <text class="detail-dual-value">{{detailItem.usageModel.useCostText}}/次</text>
        </view>
      </view>
      <view class="detail-dual-primary">
        <text class="detail-dual-primary-label">当前主成本口径</text>
        <text class="detail-dual-primary-value">{{detailItem.usageModel.selectedValueText}}{{detailItem.usageModel.selectedUnitText}}</text>
      </view>
      <text class="detail-dual-summary">{{detailItem.usageModel.summaryText}}</text>
    </view>

    <view class="detail-dust-card" wx:if="{{detailItem.costMode === 'use' && detailItem.dustRadar}}">
      <view class="detail-dust-head">
        <text class="detail-dust-title">真实吃灰指数雷达</text>
        <text class="detail-dust-tag">{{detailItem.dustRadar.levelText}}</text>
      </view>
      <view class="detail-dust-score">{{detailItem.dustRadar.index}}%</view>
      <view class="detail-dust-track">
        <view class="detail-dust-fill" style="width: {{detailItem.dustRadar.trackWidth}};"></view>
      </view>
      <view class="detail-dust-grid">
        <view class="detail-dust-cell">
          <text class="detail-dust-key">活跃率</text>
          <text class="detail-dust-value">{{detailItem.dustRadar.activeRateText}}</text>
        </view>
        <view class="detail-dust-cell">
          <text class="detail-dust-key">闲置率</text>
          <text class="detail-dust-value">{{detailItem.dustRadar.idleRateText}}</text>
        </view>
      </view>
      <text class="detail-dust-summary">{{detailItem.dustRadar.summaryText}}</text>
    </view>

    <view class="detail-quantile-card">
      <view class="detail-quantile-head">
        <text class="detail-quantile-title">回本分位线</text>
        <view class="detail-quantile-head-right">
          <text class="detail-quantile-spec-btn" bindtap="onShowPaybackSpec">查看口径</text>
          <text class="detail-quantile-tag" wx:if="{{detailItem.paybackQuantile && detailItem.paybackQuantile.ready}}">{{detailItem.paybackQuantile.percentileTag}}</text>
        </view>
      </view>

      <view wx:if="{{detailItem.paybackQuantile && detailItem.paybackQuantile.ready}}">
        <view class="detail-quantile-track">
          <view class="detail-quantile-fill" style="width: {{detailItem.paybackQuantile.trackWidth}};"></view>
        </view>
        <view class="detail-quantile-foot">
          <text class="detail-quantile-level">{{detailItem.paybackQuantile.levelText}}</text>
          <text class="detail-quantile-sample">样本 {{detailItem.paybackQuantile.sampleSize}} 条 · {{detailItem.paybackQuantile.sourceText}}</text>
        </view>
        <text class="detail-quantile-hint">{{detailItem.paybackQuantile.hint}}</text>
      </view>

      <view wx:else>
        <text class="detail-quantile-empty-title">{{detailItem.paybackQuantile.title || '样本不足'}}</text>
        <text class="detail-quantile-hint">{{detailItem.paybackQuantile.hint || '继续记录资产后即可看到回本分位线'}}</text>
      </view>
    </view>

    <view class="detail-projection-card" wx:if="{{detailItem.futureProjection}}">
      <view class="detail-projection-head">
        <text class="detail-projection-title">未来回本推演</text>
        <text class="detail-projection-summary">{{detailItem.futureProjection.summaryText}}</text>
      </view>

      <view class="detail-projection-options">
        <view
          class="detail-projection-option {{detailItem.futureProjection.selectedDays === item ? 'active' : ''}}"
          wx:for="{{detailItem.futureProjection.options}}"
          wx:key="*this"
          data-days="{{item}}"
          bindtap="onSelectProjectionHorizon"
        >{{item}}天</view>
      </view>

      <view class="detail-projection-grid">
        <view class="detail-projection-cell">
          <text class="detail-projection-key">当前日均</text>
          <text class="detail-projection-value">{{detailItem.futureProjection.currentDailyText}}/天</text>
        </view>
        <view class="detail-projection-cell">
          <text class="detail-projection-key">推演日均</text>
          <text class="detail-projection-value">{{detailItem.futureProjection.projectedDailyText}}/天</text>
        </view>
        <view class="detail-projection-cell">
          <text class="detail-projection-key">预期下降</text>
          <text class="detail-projection-value">{{detailItem.futureProjection.dropDailyText}} / {{detailItem.futureProjection.dropPercentText}}</text>
        </view>
        <view class="detail-projection-cell">
          <text class="detail-projection-key">同类中位目标</text>
          <text class="detail-projection-value">{{detailItem.futureProjection.benchmarkText}}/天</text>
          <text class="detail-projection-sub">{{detailItem.futureProjection.benchmarkSourceText}}</text>
        </view>
      </view>

      <view class="detail-projection-target">
        <text class="detail-projection-target-label">达到中位目标预计还需</text>
        <text class="detail-projection-target-value">{{detailItem.futureProjection.targetNeedDaysText}}</text>
      </view>
    </view>

    <view class="detail-resale-card">
      <view class="detail-resale-head">
        <view class="detail-resale-title">
          <text class="detail-resale-icon">🤖</text>AI 智能二手预测
        </view>
        <button class="detail-resale-btn" bindtap="onPredictResale" disabled="{{detailItem.resalePredicting}}">
          {{detailItem.resalePredicting ? '预测中...' : '开始估算'}}
        </button>
      </view>

      <view class="detail-resale-body" wx:if="{{detailItem.resaleResult}}">
        <view class="detail-resale-price-row">
          <text class="detail-resale-price-label">预测残值</text>
          <text class="detail-resale-price-value">{{detailItem.resaleResult.estimatedPriceText}}</text>
          <text class="detail-resale-tag" wx:if="{{detailItem.resaleResult.depreciationRate}}">当前折损: {{detailItem.resaleResult.depreciationRate}}</text>
        </view>
        <view class="detail-resale-insight">
          <text class="detail-resale-insight-label">AI 建议</text>
          <text class="detail-resale-insight-text">{{detailItem.resaleResult.marketTrend}}</text>
        </view>
        <view class="detail-resale-meta" wx:if="{{detailItem.resaleResult.generatedAt}}">
          <text>来源：{{detailItem.resaleResult.sourceText}}</text>
          <text>模型：{{detailItem.resaleResult.modelText}}</text>
          <text>生成时间：{{detailItem.resaleResult.generatedAt}}</text>
        </view>
        <view class="detail-resale-compare">
          <text>若今日按此价出手，时间成本将降至：</text>
          <text class="detail-resale-compare-strong">{{detailItem.resaleResult.netDailyText}}/天</text>
        </view>
      </view>
      <view class="detail-resale-empty" wx:else>
        结合大模型分析当前品类贬值曲线及二手行情，快速测算今日卖出的真实日均变化。
      </view>
    </view>

    <view class="detail-info-card">
      <view class="detail-info-row">
        <text class="detail-info-key">价格</text>
        <text class="detail-info-value">{{detailItem.totalText}}</text>
      </view>
      <view class="detail-info-row">
        <text class="detail-info-key">类别</text>
        <text class="detail-info-value">{{detailItem.category}}</text>
      </view>
      <view class="detail-info-row">
        <text class="detail-info-key">购买日期</text>
        <text class="detail-info-value">{{detailItem.dateText}}</text>
      </view>
    </view>

    <view class="detail-delete-btn" bindtap="onDeleteDetailAsset">删除</view>
  </view>

  <view class="editor-page" wx:if="{{editorVisible}}" style="padding-top: {{navStatusHeight + 8}}px;">
    <view class="editor-top">
      <view class="editor-close" bindtap="onCloseEditor">✕</view>
      <view class="editor-tabs {{editorTab === 'asset' ? 'asset-active' : 'wish-active'}}">
        <view
          class="editor-tab {{editorTab === item.id ? 'active' : ''}}"
          wx:for="{{editorTabs}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="onEditorTabChange"
        >
          {{item.text}}
        </view>
      </view>
    </view>

    <scroll-view class="editor-scroll" scroll-y="true" enhanced="true" enable-flex="true" show-scrollbar="false">
      <view class="editor-scroll-inner">
        <!-- OCR Card -->
        <view class="ocr-card" bindtap="onTapOcrImport" wx:if="{{editorMode === 'create'}}">
          <view class="ocr-left">
            <view class="ocr-icon">✨</view>
            <view class="ocr-text">
              <view class="ocr-title">截图/照片 智能识别</view>
              <view class="ocr-desc">一键提取商品、金额与时间</view>
            </view>
          </view>
          <view class="ocr-right">
            <text class="ocr-btn">智能添加</text>
          </view>
        </view>
        <view class="editor-avatar-wrap">
          <view class="editor-avatar">
            <image class="editor-avatar-image" wx:if="{{formIconType === 'image' && formIconImagePath}}" src="{{formIconImagePath}}" mode="aspectFill" />
            <text wx:else>{{formIconEmoji || (editorTab === 'asset' ? '📦' : '🎯')}}</text>
          </view>
          <view class="icon-edit-fab" bindtap="onTapIconEdit">✎</view>
        </view>
        <input class="editor-name" placeholder="{{editorTab === 'asset' ? '请输入物品名称' : '请输入心愿名称'}}" value="{{formModel.name}}" data-field="name" bindinput="onFormInput" />

        <view class="editor-card">
          <view class="editor-cell">
            <text class="cell-left">价格</text>
            <view class="cell-right price-value-trigger" bindtap="onOpenPriceCurrencyModal">
              {{formModel.price || '请输入金额'}} {{selectedPriceCurrencyCode}} ›
            </view>
          </view>
        </view>

        <view class="editor-card" wx:if="{{editorTab === 'asset'}}">
          <view class="editor-cell">
            <text class="cell-left">购买日期</text>
            <picker mode="date" value="{{formModel.date}}" bindchange="onFormDateChange">
              <view class="cell-right">{{formModel.date || '请选择'}} ›</view>
            </picker>
          </view>
          <view class="editor-cell">
            <text class="cell-left">类别</text>
            <picker mode="selector" range="{{categoryOptions}}" value="{{categoryIndex}}" bindchange="onCategoryChange">
              <view class="cell-right">{{categoryOptions[categoryIndex]}} ›</view>
            </picker>
          </view>
          <view class="editor-cell last">
            <text class="cell-left">标签</text>
            <view class="cell-right">未设置 ›</view>
          </view>
        </view>

        <view class="editor-card" wx:if="{{editorTab === 'asset'}}">
          <view class="editor-title">目标成本</view>
          <view class="cost-mode-wrap">
            <view
              class="cost-chip {{activeCostMode === item.id ? 'active' : ''}}"
              wx:for="{{costModes}}"
              wx:key="id"
              data-id="{{item.id}}"
              bindtap="onCostModeChange"
            >
              {{item.text}}
            </view>
          </view>
        </view>

        <view class="editor-resale-card" wx:if="{{editorTab === 'asset'}}">
          <view class="editor-resale-head">
            <view class="editor-resale-title">
              <text class="editor-resale-icon">🤖</text>AI 智能二手预测
            </view>
            <button class="editor-resale-btn" bindtap="onPredictEditorResale" disabled="{{editorResalePredicting}}">
              {{editorResalePredicting ? '预测中...' : '开始估算'}}
            </button>
          </view>

          <view class="editor-resale-body" wx:if="{{editorResaleResult}}">
            <view class="editor-resale-price-row">
              <text class="editor-resale-price-label">预测残值</text>
              <text class="editor-resale-price-value">{{editorResaleResult.estimatedPriceText}}</text>
              <text class="editor-resale-tag" wx:if="{{editorResaleResult.depreciationRate}}">当前折损: {{editorResaleResult.depreciationRate}}</text>
            </view>
            <view class="editor-resale-insight">
              <text class="editor-resale-insight-label">AI 建议</text>
              <text class="editor-resale-insight-text">{{editorResaleResult.marketTrend}}</text>
            </view>
            <view class="editor-resale-compare">
              <text>若今日按此价出手，时间成本将降至：</text>
              <text class="editor-resale-compare-strong">{{editorResaleResult.netDailyText}}/天</text>
            </view>
            <view class="editor-resale-actions">
              <view class="editor-resale-apply" bindtap="onApplyEditorResalePrice">回填到卖出价格</view>
            </view>
          </view>
          <view class="editor-resale-empty" wx:else>
            结合大模型分析当前品类贬值曲线及二手行情，快速测算今日卖出的真实日均变化。
          </view>
        </view>

        <view class="editor-card">
          <input class="note-input" placeholder="输入备注" value="{{formModel.note}}" data-field="note" bindinput="onFormInput" />
          <view class="note-media-row">
            <view class="note-media-slot" bindtap="onChooseNoteImage">🖼</view>
            <view class="note-media-preview" wx:if="{{noteImagePath}}">
              <image class="note-media-image" src="{{noteImagePath}}" mode="aspectFill" bindtap="onPreviewNoteImage" />
              <view class="note-media-remove" bindtap="onRemoveNoteImage">×</view>
            </view>
          </view>
        </view>

        <view class="editor-card">
          <view class="editor-title">附加物品</view>
          <view class="related-draft-row">
            <input class="related-input name" placeholder="名称" value="{{relatedDraft.name}}" data-field="name" bindinput="onRelatedInput" />
            <input class="related-input qty" type="number" placeholder="数量" value="{{relatedDraft.qty}}" data-field="qty" bindinput="onRelatedInput" />
            <view class="related-input price related-price-trigger" bindtap="onOpenRelatedCurrencyModal">
              {{relatedDraft.price || '单价'}} {{selectedRelatedCurrencyCode}} ›
            </view>
          </view>
          <view class="related-list" wx:if="{{relatedList.length}}">
            <view class="related-item" wx:for="{{relatedList}}" wx:key="id">
              <text class="related-name">{{item.name}} ×{{item.qty}}</text>
              <view class="related-right">
                <text class="related-amount">{{item.amountText}}</text>
                <text class="related-remove" data-id="{{item.id}}" bindtap="onRemoveRelatedItem">删除</text>
              </view>
            </view>
            <view class="related-total">附加总计 {{relatedTotalText}}</view>
          </view>
        </view>

        <view class="editor-card" wx:if="{{editorTab === 'asset'}}">
          <view class="toggle-row">
            <view class="toggle-label">
              <text class="row-icon">📦</text>
              <text>已退役</text>
            </view>
            <switch checked="{{statusSwitches.retired}}" color="#11131d" data-key="retired" bindchange="onFormStatusChange" />
          </view>
          <view class="toggle-row">
            <view class="toggle-label">
              <text class="row-icon">📤</text>
              <text>卖出的</text>
            </view>
            <switch checked="{{statusSwitches.sold}}" color="#11131d" data-key="sold" bindchange="onFormStatusChange" />
          </view>
        </view>

        <view class="editor-card" wx:if="{{editorTab === 'asset' && statusSwitches.sold}}">
          <view class="editor-cell">
            <text class="cell-left">卖出价格</text>
            <input class="cell-right-input" placeholder="请输入卖出价格" type="digit" value="{{formModel.resalePrice}}" data-field="resalePrice" bindinput="onFormInput" />
          </view>
        </view>

        <view class="editor-card" wx:if="{{editorTab === 'asset'}}">
          <view class="toggle-row">
            <view class="toggle-label">
              <text class="row-icon">⌃</text>
              <text>置顶</text>
              <text class="row-badge">✓</text>
            </view>
            <switch checked="{{toggles.pinned}}" color="#11131d" data-key="pinned" bindchange="onToggleSetting" />
          </view>
          <view class="toggle-row">
            <view class="toggle-label">
              <text class="row-icon">💰</text>
              <text>不计入总资产</text>
              <text class="row-badge">✓</text>
            </view>
            <switch checked="{{toggles.excludeAsset}}" color="#11131d" data-key="excludeAsset" bindchange="onToggleSetting" />
          </view>
          <view class="toggle-row">
            <view class="toggle-label">
              <text class="row-icon">☰</text>
              <text>不计入日均</text>
              <text class="row-badge">✓</text>
            </view>
            <switch checked="{{toggles.excludeDaily}}" color="#11131d" data-key="excludeDaily" bindchange="onToggleSetting" />
          </view>
        </view>

        <view class="save-btn" bindtap="onSubmitEditor">{{editorMode === 'edit' ? '更新' : '保存'}}</view>
      </view>
    </scroll-view>

    <view class="icon-library-mask" wx:if="{{iconLibraryVisible}}" bindtap="onCloseIconLibraryPanel"></view>
    <view class="price-currency-mask" wx:if="{{showPriceCurrencyModal}}" bindtap="onClosePriceCurrencyModal"></view>
    <view class="price-currency-panel" wx:if="{{showPriceCurrencyModal}}">
      <view class="price-currency-title">选择币种</view>
      <view class="price-currency-grid">
        <view
          class="price-currency-item {{selectedPriceCurrencyCode === item.code ? 'active' : ''}}"
          wx:for="{{allCurrencyList}}"
          wx:key="code"
          data-code="{{item.code}}"
          data-name="{{item.name}}"
          bindtap="onSelectPriceCurrency"
        >{{item.code}}</view>
      </view>

      <view class="price-currency-input-wrap">
        <input class="price-currency-input" type="digit" placeholder="请输入金额" value="{{formModel.price}}" bindinput="onPriceInput" focus="{{showPriceCurrencyModal}}" />
      </view>

      <view class="price-currency-actions">
        <view class="price-currency-cancel" bindtap="onClosePriceCurrencyModal">取消</view>
        <view class="price-currency-confirm" bindtap="onConfirmPriceCurrency">确认添加</view>
      </view>
    </view>

    <view class="price-currency-mask" wx:if="{{showRelatedCurrencyModal}}" bindtap="onCloseRelatedCurrencyModal"></view>
    <view class="price-currency-panel" wx:if="{{showRelatedCurrencyModal}}">
      <view class="price-currency-title">选择附加物品币种</view>
      <view class="price-currency-grid">
        <view
          class="price-currency-item {{selectedRelatedCurrencyCode === item.code ? 'active' : ''}}"
          wx:for="{{allCurrencyList}}"
          wx:key="code"
          data-code="{{item.code}}"
          data-name="{{item.name}}"
          bindtap="onSelectRelatedCurrency"
        >{{item.code}}</view>
      </view>

      <view class="price-currency-input-wrap">
        <input class="price-currency-input" type="digit" placeholder="请输入单价" value="{{relatedDraft.price}}" bindinput="onRelatedPriceInput" focus="{{showRelatedCurrencyModal}}" />
      </view>

      <view class="price-currency-actions">
        <view class="price-currency-cancel" bindtap="onCloseRelatedCurrencyModal">取消</view>
        <view class="price-currency-confirm" bindtap="onConfirmRelatedCurrency">确认添加</view>
      </view>
    </view>
    <view class="icon-library-panel" wx:if="{{iconLibraryVisible}}">
      <view class="icon-library-head compact">
        <text class="icon-head-action" bindtap="onCloseIconLibraryPanel">取消</text>
        <view class="icon-mode-tabs">
          <view class="icon-mode-tab {{iconPickerTab === 'album' ? 'active' : ''}}" data-tab="album" bindtap="onIconPickerTabTap">相册</view>
          <view class="icon-mode-tab {{iconPickerTab === 'emoji' ? 'active' : ''}}" data-tab="emoji" bindtap="onIconPickerTabTap">Emoji</view>
          <view class="icon-mode-tab {{iconPickerTab === 'library' ? 'active' : ''}}" data-tab="library" bindtap="onIconPickerTabTap">图标</view>
        </view>
        <text class="icon-head-action strong" bindtap="onConfirmIconLibraryPanel">确定</text>
      </view>

      <view class="icon-selected-preview">
        <view class="icon-selected-thumb-wrap">
          <image class="icon-selected-thumb" wx:if="{{iconPickerDraftType === 'image' && iconPickerDraftImagePath}}" src="{{iconPickerDraftImagePath}}" mode="aspectFit" />
          <text class="icon-selected-emoji" wx:else>{{iconPickerDraftEmoji}}</text>
        </view>
      </view>

      <view class="emoji-grid-wrap" wx:if="{{iconPickerTab === 'emoji'}}">
        <view class="emoji-grid">
          <view
            class="emoji-grid-item {{iconPickerDraftType === 'emoji' && iconPickerDraftEmoji === item ? 'active' : ''}}"
            wx:for="{{iconPresets}}"
            wx:key="*this"
            data-emoji="{{item}}"
            bindtap="onPickIconEmoji"
          >{{item}}</view>
        </view>
      </view>

      <view class="icon-album-wrap" wx:if="{{iconPickerTab === 'album'}}">
        <view class="icon-album-btn" bindtap="onChooseIconImage">从相册选择图片</view>
      </view>

      <scroll-view class="icon-category-scroll" scroll-x="true" enhanced="true" show-scrollbar="false" wx:if="{{iconPickerTab === 'library'}}">
        <view class="icon-category-row">
          <view
            class="icon-category-chip {{iconLibraryActiveCategory === item ? 'active' : ''}}"
            wx:for="{{iconLibraryCategories}}"
            wx:key="*this"
            data-category="{{item}}"
            bindtap="onIconLibraryCategoryTap"
          >{{item}}</view>
        </view>
      </scroll-view>

      <view class="icon-library-search-row" wx:if="{{iconPickerTab === 'library'}}">
        <input class="icon-library-search-input" placeholder="搜索图标名称/分类" value="{{iconLibraryKeyword}}" bindinput="onIconLibrarySearchInput" />
      </view>

      <view class="icon-library-loading" wx:if="{{iconPickerTab === 'library' && iconLibraryLoading}}">加载中...</view>

      <scroll-view class="icon-grid-scroll" scroll-y="true" enhanced="true" show-scrollbar="false" bindscrolltolower="onIconLibraryScrollToLower" wx:if="{{iconPickerTab === 'library' && !iconLibraryLoading}}">
        <view class="icon-grid">
          <view
            class="icon-grid-item"
            wx:for="{{iconLibraryDisplayedItems}}"
            wx:key="id"
            data-path="{{item.path}}"
            data-name="{{item.name}}"
            data-id="{{item.id}}"
            data-category="{{item.category}}"
            data-source="{{item.source}}"
            bindtap="onPickLibraryIcon"
          >
            <view class="icon-grid-thumb-wrap">
              <image class="icon-grid-thumb" src="{{item.path}}" mode="aspectFit" binderror="onIconGridImageError" data-index="{{index}}" />
            </view>
            <text class="icon-grid-name">{{item.name}}</text>
          </view>
        </view>
        <view class="icon-grid-footer" wx:if="{{iconLibraryDisplayedItems.length && iconLibraryHasMore}}">上拉加载更多...</view>
        <view class="icon-grid-footer" wx:if="{{iconLibraryDisplayedItems.length && !iconLibraryHasMore}}">已加载全部</view>
        <view class="icon-grid-empty" wx:if="{{!iconLibraryDisplayedItems.length}}">未找到匹配图标</view>
      </scroll-view>
    </view>
  </view>
</view>
