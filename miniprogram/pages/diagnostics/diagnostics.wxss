.container {
  padding: 30rpx;
  min-height: 100vh;
  background: #f5f7fa;
}

.card {
  background: #fff;
  border-radius: 18rpx;
  box-shadow: 0 6rpx 20rpx rgba(15, 23, 42, 0.05);
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.page-head {
  background: linear-gradient(135deg, #153b63, #0f766e);
}

.page-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #ffffff;
}

.page-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.82);
}

.hero-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
  flex-wrap: wrap;
}

.hero-btn {
  margin: 0;
  padding: 0 28rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  color: #ffffff;
  font-size: 26rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.18);
}

.hero-btn::after,
.run-btn::after {
  border: none;
}

.hero-btn-primary {
  background: #ffffff;
  color: #123456;
}

.tips {
  font-size: 24rpx;
  line-height: 1.6;
  color: #64748b;
}

.summary-strip {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.summary-box {
  padding: 20rpx;
  border-radius: 18rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
}

.summary-label {
  font-size: 22rpx;
  color: #64748b;
}

.summary-value {
  margin-top: 10rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
}

.summary-value.small {
  font-size: 22rpx;
  line-height: 1.6;
  word-break: break-all;
}

.summary-value.success {
  color: #15803d;
}

.summary-value.error {
  color: #b91c1c;
}

.card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.diagnostic-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #0f172a;
}

.diagnostic-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #64748b;
}

.status-badge {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.status-idle {
  background: #e2e8f0;
  color: #475569;
}

.status-running {
  background: #dbeafe;
  color: #1d4ed8;
}

.status-success {
  background: #dcfce7;
  color: #15803d;
}

.status-error {
  background: #fee2e2;
  color: #b91c1c;
}

.card-summary {
  margin-top: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #f8fafc;
  font-size: 24rpx;
  line-height: 1.6;
  color: #0f172a;
}

.card-meta {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.tushare-form {
  margin-top: 16rpx;
}

.diagnostic-input {
  width: 100%;
  min-height: 84rpx;
  margin-top: 16rpx;
  padding: 0 22rpx;
  border-radius: 14rpx;
  background: #f8fafc;
  border: 1rpx solid #dbe3ee;
  box-sizing: border-box;
}

.diagnostic-input:first-child {
  margin-top: 0;
}

.run-btn {
  margin-top: 24rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #1890ff, #40a9ff);
  color: #fff;
  font-size: 26rpx;
  height: 72rpx;
  line-height: 72rpx;
}

.result-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.result-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #0f172a;
}

.result-tag {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #e2e8f0;
  color: #475569;
  font-size: 22rpx;
}

.result-scroll {
  max-height: 720rpx;
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 14rpx;
  background: #0f172a;
}

.result-text {
  font-family: Consolas, Monaco, monospace;
  font-size: 22rpx;
  line-height: 1.7;
  color: #dbeafe;
  white-space: pre-wrap;
  word-break: break-all;
}