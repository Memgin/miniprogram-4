.container {
  padding: 30rpx;
  min-height: 100vh;
  background: #f5f7fa;
}

.card {
  background: #fff;
  border-radius: 18rpx;
  box-shadow: 0 6rpx 20rpx rgba(15, 23, 42, 0.05);
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.page-head {
  background: linear-gradient(135deg, #153b63, #0f766e);
}

.page-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #ffffff;
}

.page-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.82);
}

.hero-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
  flex-wrap: wrap;
}

.hero-btn {
  margin: 0;
  padding: 0 28rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  color: #ffffff;
  font-size: 26rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.18);
}

.hero-btn::after,
.run-btn::after {
  border: none;
}

.hero-btn-primary {
  background: #ffffff;
  color: #123456;
}

.tips {
  font-size: 24rpx;
  line-height: 1.6;
  color: #64748b;
}

.summary-strip {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.summary-box {
  padding: 20rpx;
  border-radius: 18rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
}

.summary-label {
  font-size: 22rpx;
  color: #64748b;
}

.summary-value {
  margin-top: 10rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
}

.summary-value.small {
  font-size: 22rpx;
  line-height: 1.6;
  word-break: break-all;
}

.summary-value.success {
  color: #15803d;
}

.summary-value.error {
  color: #b91c1c;
}

.card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.diagnostic-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #0f172a;
}

.diagnostic-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #64748b;
}

.status-badge {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.status-idle {
  background: #e2e8f0;
  color: #475569;
}

.status-running {
  background: #dbeafe;
  color: #1d4ed8;
}

.status-success {
  background: #dcfce7;
  color: #15803d;
}

.status-error {
  background: #fee2e2;
  color: #b91c1c;
}

.card-summary {
  margin-top: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #f8fafc;
  font-size: 24rpx;
  line-height: 1.6;
  color: #0f172a;
}

.card-meta {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.tushare-form {
  margin-top: 16rpx;
}

.diagnostic-input {
  width: 100%;
  min-height: 84rpx;
  margin-top: 16rpx;
  padding: 0 22rpx;
  border-radius: 14rpx;
  background: #f8fafc;
  border: 1rpx solid #dbe3ee;
  box-sizing: border-box;
}

.diagnostic-input:first-child {
  margin-top: 0;
}

.run-btn {
  margin-top: 24rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #1890ff, #40a9ff);
  color: #fff;
  font-size: 26rpx;
  height: 72rpx;
  line-height: 72rpx;
}

.result-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.result-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #0f172a;
}

.result-tag {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #e2e8f0;
  color: #475569;
  font-size: 22rpx;
}

.result-scroll {
  max-height: 720rpx;
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 14rpx;
  background: #0f172a;
}

.result-text {
  font-family: Consolas, Monaco, monospace;
  font-size: 22rpx;
  line-height: 1.7;
  color: #dbeafe;
  white-space: pre-wrap;
  word-break: break-all;
}

/* Liquid Glass Harmonization */
.container {
  background:
    radial-gradient(circle at 10% -10%, rgba(143, 244, 120, 0.18) 0%, rgba(143, 244, 120, 0) 28%),
    radial-gradient(circle at 90% -8%, rgba(145, 214, 255, 0.2) 0%, rgba(145, 214, 255, 0) 28%),
    linear-gradient(170deg, #f8fbff 0%, #edf1f8 100%);
}

.card,
.summary-box,
.card-summary {
  background: linear-gradient(150deg, rgba(255, 255, 255, 0.82), rgba(255, 255, 255, 0.62));
  border: 1rpx solid rgba(255, 255, 255, 0.56);
  backdrop-filter: blur(14rpx) saturate(1.14);
  -webkit-backdrop-filter: blur(14rpx) saturate(1.14);
  box-shadow: 0 14rpx 30rpx rgba(15, 23, 42, 0.1);
}

.run-btn,
.hero-btn-primary {
  background: linear-gradient(140deg, #151d2f, #0c1324);
  color: #ffffff;
}

/* System polish */
.card,
.summary-box,
.card-summary,
.result-scroll {
  border-radius: 24rpx;
}

.page-title,
.diagnostic-title,
.result-title {
  letter-spacing: 0.2rpx;
}

/* Liquid Glass Unified Final Override */
.container {
  background:
    radial-gradient(circle at 12% -8%, rgba(255, 255, 255, 0.4) 0%, rgba(255, 255, 255, 0) 30%),
    radial-gradient(circle at 90% 6%, rgba(214, 194, 168, 0.22) 0%, rgba(214, 194, 168, 0) 30%),
    linear-gradient(180deg, #f6f4f1 0%, #f1eee9 100%) !important;
}

.card,
.summary-box,
.card-summary,
.result-scroll {
  background: linear-gradient(154deg, rgba(255, 255, 255, 0.74), rgba(247, 241, 233, 0.56)) !important;
  border: 1rpx solid rgba(255, 255, 255, 0.72) !important;
  backdrop-filter: blur(14rpx) saturate(1.03);
  -webkit-backdrop-filter: blur(14rpx) saturate(1.03);
  box-shadow: 0 10rpx 24rpx rgba(66, 53, 39, 0.09) !important;
}

.run-btn,
.hero-btn-primary {
  background: linear-gradient(140deg, #7a6348, #5f4d39) !important;
  color: #fff8ef !important;
  border-color: rgba(255, 255, 255, 0.42) !important;
}

/* Liquid Glass Main Inspired Finish */
.container {
  background:
    radial-gradient(circle at 14% -10%, rgba(255, 255, 255, 0.46) 0%, rgba(255, 255, 255, 0) 32%),
    radial-gradient(circle at 90% 8%, rgba(220, 198, 170, 0.22) 0%, rgba(220, 198, 170, 0) 30%),
    linear-gradient(180deg, #f6f4f1 0%, #f1eee9 100%) !important;
}

.card,
.summary-box,
.card-summary,
.result-scroll {
  background: linear-gradient(160deg, rgba(255, 255, 255, 0.84), rgba(243, 235, 226, 0.58)) !important;
  border: 1rpx solid rgba(255, 255, 255, 0.78) !important;
  box-shadow: 0 8rpx 18rpx rgba(0, 0, 0, 0.16), 0 -16rpx 28rpx inset rgba(0, 0, 0, 0.08), 0 1rpx 0 inset rgba(255, 255, 255, 0.78) !important;
  backdrop-filter: blur(16rpx) contrast(1.12) brightness(1.03) saturate(1.08);
  -webkit-backdrop-filter: blur(16rpx) contrast(1.12) brightness(1.03) saturate(1.08);
}