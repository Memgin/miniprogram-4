<view class="container">
  <!-- 导出为文本 -->
  <view class="export-item card" bindtap="exportText">
    <view class="item-icon">📝</view>
    <view class="item-text">导出为文本</view>
    <view class="item-arrow">→</view>
  </view>

  <!-- 导出为图片 -->
  <view class="export-item card" bindtap="exportImage">
    <view class="item-icon">🖼️</view>
    <view class="item-text">导出为图片</view>
    <view class="item-arrow">→</view>
  </view>

  <!-- 隐藏的canvas（用于生成图片） -->
  <canvas canvas-id="exportCanvas" class="canvas-hidden"></canvas>
</view>