.container {
  padding: 30rpx;
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(59, 130, 246, 0.1), transparent 25%),
    linear-gradient(180deg, #f8fbff 0%, #eff4fb 100%);
}

.export-hero {
  padding: 34rpx;
  margin-bottom: 22rpx;
  background: linear-gradient(135deg, #102a43, #1d4ed8 56%, #0f766e);
  color: #ffffff;
  box-shadow: 0 20rpx 44rpx rgba(15, 23, 42, 0.16);
}

.export-hero-title {
  font-size: 38rpx;
  font-weight: 700;
}

.export-hero-subtitle {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.76);
}

.export-hero-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 22rpx;
}

.export-hero-box {
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.16);
}

.export-hero-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.72);
}

.export-hero-value {
  margin-top: 10rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.export-hero-value-small {
  font-size: 24rpx;
  line-height: 1.6;
}

.export-hero-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 22rpx;
}

.export-hero-btn {
  flex: 1 1 200rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.12);
  color: #ffffff;
  font-size: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.18);
}

.export-hero-btn-primary {
  background: #ffffff;
  color: #102a43;
}

.export-status {
  padding: 28rpx 30rpx;
  margin-bottom: 20rpx;
}

.export-status-title,
.export-empty-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
}

.export-status-line,
.export-empty-text {
  margin-top: 12rpx;
  font-size: 23rpx;
  line-height: 1.7;
  color: #64748b;
}

.preview-card {
  padding: 30rpx;
}

.preview-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
}

.preview-subtitle {
  margin-top: 10rpx;
  font-size: 23rpx;
  line-height: 1.6;
  color: #64748b;
}

.preview-block {
  margin-top: 22rpx;
}

.preview-block-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #334155;
}

.preview-row {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #eef2f7;
  font-size: 23rpx;
  color: #475569;
}

.preview-row:last-child {
  border-bottom: none;
}
.export-empty {
  padding: 36rpx 30rpx;
  text-align: center;
}

.canvas-hidden {
  position: fixed;
  top: -99999px;
  left: -99999px;
  width: 700px;
  height: 4200px;
  opacity: 0;
  pointer-events: none;
}

/* Liquid Glass Harmonization */
.container {
  background:
    radial-gradient(circle at 10% -10%, rgba(143, 244, 120, 0.18) 0%, rgba(143, 244, 120, 0) 28%),
    radial-gradient(circle at 90% -8%, rgba(145, 214, 255, 0.2) 0%, rgba(145, 214, 255, 0) 28%),
    linear-gradient(170deg, #f8fbff 0%, #edf1f8 100%);
}

.card,
.preview-card,
.export-status,
.export-empty,
.export-hero-box {
  background: linear-gradient(150deg, rgba(255, 255, 255, 0.82), rgba(255, 255, 255, 0.62));
  border: 1rpx solid rgba(255, 255, 255, 0.56);
  backdrop-filter: blur(14rpx) saturate(1.14);
  -webkit-backdrop-filter: blur(14rpx) saturate(1.14);
  box-shadow: 0 14rpx 30rpx rgba(15, 23, 42, 0.1);
}

.export-hero-btn-primary {
  background: linear-gradient(140deg, #151d2f, #0c1324);
  color: #ffffff;
}

/* System polish */
.export-hero,
.preview-card,
.export-status,
.export-empty {
  border-radius: 24rpx;
}

.export-hero-title,
.preview-title,
.export-status-title {
  letter-spacing: 0.2rpx;
}

/* Liquid Glass Unified Final Override */
.container {
  background:
    radial-gradient(circle at 12% -8%, rgba(255, 255, 255, 0.4) 0%, rgba(255, 255, 255, 0) 30%),
    radial-gradient(circle at 90% 6%, rgba(214, 194, 168, 0.22) 0%, rgba(214, 194, 168, 0) 30%),
    linear-gradient(180deg, #f6f4f1 0%, #f1eee9 100%) !important;
}

.card,
.preview-card,
.export-status,
.export-empty,
.export-hero,
.export-hero-box {
  background: linear-gradient(154deg, rgba(255, 255, 255, 0.74), rgba(247, 241, 233, 0.56)) !important;
  border: 1rpx solid rgba(255, 255, 255, 0.72) !important;
  backdrop-filter: blur(14rpx) saturate(1.03);
  -webkit-backdrop-filter: blur(14rpx) saturate(1.03);
  box-shadow: 0 10rpx 24rpx rgba(66, 53, 39, 0.09) !important;
}

.export-hero-btn,
.export-hero-btn-primary {
  background: linear-gradient(140deg, #7a6348, #5f4d39) !important;
  color: #fff8ef !important;
  border-color: rgba(255, 255, 255, 0.42) !important;
}

/* Liquid Glass Main Inspired Finish */
.container {
  background:
    radial-gradient(circle at 14% -10%, rgba(255, 255, 255, 0.46) 0%, rgba(255, 255, 255, 0) 32%),
    radial-gradient(circle at 90% 8%, rgba(220, 198, 170, 0.22) 0%, rgba(220, 198, 170, 0) 30%),
    linear-gradient(180deg, #f6f4f1 0%, #f1eee9 100%) !important;
}

.card,
.preview-card,
.export-status,
.export-empty,
.export-hero,
.export-hero-box {
  background: linear-gradient(160deg, rgba(255, 255, 255, 0.84), rgba(243, 235, 226, 0.58)) !important;
  border: 1rpx solid rgba(255, 255, 255, 0.78) !important;
  box-shadow: 0 8rpx 18rpx rgba(0, 0, 0, 0.16), 0 -16rpx 28rpx inset rgba(0, 0, 0, 0.08), 0 1rpx 0 inset rgba(255, 255, 255, 0.78) !important;
  backdrop-filter: blur(16rpx) contrast(1.12) brightness(1.03) saturate(1.08);
  -webkit-backdrop-filter: blur(16rpx) contrast(1.12) brightness(1.03) saturate(1.08);
}

/* Export readability final override */
.export-hero-title {
  color: #2f271d !important;
}

.export-hero-subtitle {
  color: #6f6254 !important;
}

.export-hero-label {
  color: #80715f !important;
}

.export-hero-value,
.export-hero-value-small {
  color: #3a3026 !important;
}

.export-hero-value-total {
  color: #d84444 !important;
}