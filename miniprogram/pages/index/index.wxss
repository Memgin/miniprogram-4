  margin-bottom: 20rpx;
  box-shadow: inset 0 2rpx 4rpx rgba(0,0,0,0.06);
}
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF7D00, #FFB547);
  border-radius: 999rpx;
  transition: width 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
