.container {
  padding: 30rpx;
  min-height: 100vh;
  background-color: #f5f7fa;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
}

.operate-bar {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.security-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, #fffaf0, #ffffff);
  border-radius: 18rpx;
  box-shadow: 0 6rpx 18rpx rgba(15, 23, 42, 0.04);
}

.security-toolbar-main {
  flex: 1;
  display: flex;
  align-items: center;
  min-width: 0;
}

.security-eye-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #fff3d9;
  border: 1rpx solid #f8d57e;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.security-eye {
  position: relative;
  width: 34rpx;
  height: 20rpx;
  border: 3rpx solid #7c4f00;
  border-radius: 24rpx / 14rpx;
}

.security-eye-pupil {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 10rpx;
  height: 10rpx;
  background: #7c4f00;
  border-radius: 50%;
  transform: translate(-50%, -50%);
}

.security-eye-off {
  opacity: 0.6;
}

.security-eye-strike {
  position: absolute;
  top: 50%;
  left: -4rpx;
  width: 42rpx;
  height: 3rpx;
  background: #7c4f00;
  transform: rotate(-28deg);
}

.security-toolbar-copy {
  min-width: 0;
  margin-left: 16rpx;
}

.security-toolbar-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1e293b;
}

.security-toolbar-subtitle {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #7c8aa0;
}

.security-compact-toggle {
  padding: 14rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #7c4f00;
  background: #fff3d9;
  border: 1rpx solid #f8d57e;
  flex-shrink: 0;
}

.security-compact-toggle-active {
  color: #125d35;
  background: #eaf8ef;
  border-color: #9dd9b6;
}
.add-btn {
  flex: 1;
  background: linear-gradient(135deg, #1890ff, #40a9ff);
  color: #fff;
  border-radius: 16rpx;
  font-size: 28rpx;
  padding: 20rpx 0;
  box-shadow: 0 4rpx 12rpx rgba(24, 144, 255, 0.2);
  transition: all 0.2s ease;
}
.add-btn:active {
  background: linear-gradient(135deg, #096dd9, #1890ff);
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 8rpx rgba(24, 144, 255, 0.15);
}
.export-btn {
  flex: 1;
  background: linear-gradient(135deg, #faad14, #ffc53d);
  color: #fff;
  border-radius: 16rpx;
  font-size: 28rpx;
  padding: 20rpx 0;
  box-shadow: 0 4rpx 12rpx rgba(250, 173, 20, 0.2);
  transition: all 0.2s ease;
}
.export-btn:active {
  background: linear-gradient(135deg, #d48806, #faad14);
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 8rpx rgba(250, 173, 20, 0.15);
}

.rate-card, .summary-card {
  padding: 32rpx;
  margin-bottom: 24rpx;
  background: #fff;
  border-radius: 18rpx;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.04), 0 2rpx 8rpx rgba(0,0,0,0.02);
  border: 1px solid rgba(255, 255, 255, 0.9);
  position: relative;
}
.total-card {
  padding: 40rpx 36rpx 0rpx;
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%);
  border-radius: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.06), 0 2rpx 8rpx rgba(0,0,0,0.04);
  border: 1px solid rgba(255, 255, 255, 0.8);
  position: relative;
  overflow: hidden;
}

.total-card-clickable {
  cursor: pointer;
}

.total-card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.total-card-copy {
  flex: 1;
  min-width: 0;
}

.total-card-title {
  margin-bottom: 10rpx;
}

.total-card-subtitle {
  font-size: 24rpx;
  line-height: 1.6;
  color: #64748b;
}

.total-card-security {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.total-card-metrics {
  display: grid;
  grid-template-columns: 1fr;
  gap: 18rpx;
  margin-top: 28rpx;
}

.total-card-metric {
  padding: 24rpx 26rpx;
  border-radius: 20rpx;
  background: rgba(241, 245, 249, 0.9);
}

.total-card-metric-primary {
  background: linear-gradient(135deg, #f8fafc, #eef6ff);
}

.total-card-metric-clickable {
  cursor: pointer;
}

.total-card-metric-clickable:active {
  transform: translateY(2rpx);
}

.total-card-metric-label {
  font-size: 22rpx;
  color: #64748b;
}

.total-card-metric-value {
  margin-top: 10rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: #0f172a;
}

.total-card-metric-note {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #64748b;
  line-height: 1.5;
}

.total-card-progress {
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(148, 163, 184, 0.18);
}

.total-card-progress-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.total-card-progress-label {
  font-size: 22rpx;
  color: #64748b;
}

.total-card-progress-value {
  margin-top: 8rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: #0f172a;
}

.total-card-progress-body {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 8rpx;
}

.total-card-progress-side {
  flex-shrink: 0;
  text-align: right;
}

.total-card-progress-note {
  margin-top: 0;
  line-height: 1.4;
}

.total-card-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.top-action-btn {
  flex: 1;
  height: 78rpx;
  line-height: 78rpx;
  border-radius: 18rpx;
  background: #e8f0fb;
  color: #12314c;
  font-size: 24rpx;
  font-weight: 600;
  border: 1rpx solid #d8e4f3;
}

.top-action-btn::after {
  border: none;
}

.total-card-links {
  display: flex;
  flex-wrap: wrap;
  gap: 22rpx;
  margin-top: 20rpx;
}

.total-card-links-inline {
  margin-top: 20rpx;
}

.total-card-link {
  font-size: 24rpx;
  color: #175cd3;
}

.total-card-entry {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #64748b;
}
.total-card::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  width: 6rpx;
  height: 100%;
  background: linear-gradient(180deg, #ff6b6b, #ff8e8e);
  border-top-left-radius: 20rpx;
  border-bottom-left-radius: 20rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  color: #1e293b;
  letter-spacing: 0.6rpx;
  line-height: 1.3;
}

@media (max-width: 680rpx) {
  .total-card-top,
  .total-card-actions,
  .total-card-security,
  .empty-workspace-actions {
    flex-direction: column;
    align-items: stretch;
  }

  .total-card-metrics {
    grid-template-columns: 1fr;
  }
}

.rate-item, .summary-item {
  display: flex;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
  align-items: center;
}
.rate-item:last-child, .summary-item:last-child {
  border-bottom: none;
}

.linked-highlight {
  margin-left: -12rpx;
  margin-right: -12rpx;
  padding-left: 12rpx;
  padding-right: 12rpx;
  border-radius: 14rpx;
  background: linear-gradient(135deg, #fff8db, #fff1bf);
  border-bottom-color: transparent;
}
.rate-name, .currency-name {
  width: 160rpx;
  color: #475569;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 28rpx;
}
.rate-name-wrap {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 220rpx;
}
.ai-monitor-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 2rpx 10rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #125d35;
  background: #eaf8ef;
  border: 1rpx solid #9dd9b6;
}
.rate-value, .currency-amount {
  flex: 1;
  text-align: right;
  padding-right: 20rpx;
  white-space: nowrap;
  font-size: 28rpx;
  color: #1e293b;
  font-weight: 500;
}
.cny-amount {
  width: 180rpx;
  font-size: 26rpx;
  color: #94a3b8;
  text-align: right;
  white-space: nowrap;
}

/* 银行卡列表标题：和卡片标题统一风格 */
.card-list .list-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  color: #1e293b;
  letter-spacing: 0.5rpx;
}

/* ========== 左滑删除样式（统一高级质感） ========== */
.card-swipe-wrapper {
  position: relative;
  width: 100%;
  height: auto;
  margin-bottom: 24rpx;
  border-radius: 18rpx;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.04), 0 2rpx 8rpx rgba(0,0,0,0.02);
  overflow: hidden !important;
}
/* 银行卡卡片：和其他卡片统一圆角/内边距 */
.bank-card-item {
  width: 100%;
  background: #fff;
  border-radius: 18rpx;
  padding: 32rpx;
  box-sizing: border-box;
  position: relative;
  z-index: 2;
  transition: all 0.2s ease;
}
.bank-card-item:active {
  background: #f8fafc;
  transform: scale(0.99);
}
/* 删除按钮：渐变红色+圆角 */
.delete-btn {
  position: absolute;
  right: 0;
  top: 0;
  width: 120rpx;
  height: 100%;
  background: linear-gradient(135deg, #ff4444, #ff6666);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  z-index: 1;
  border-top-right-radius: 18rpx;
  border-bottom-right-radius: 18rpx;
}

/* 银行卡内容：统一文字层级和颜色 */
.bank-card-item .card-name {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: #1e293b;
}
.bank-card-item .card-total-cny {
  font-size: 26rpx;
  color: #475569;
  margin: 12rpx 0 20rpx;
}
.bank-card-item .card-currencies {
  padding: 8rpx 0;
  color: #475569;
  line-height: 38rpx;
  font-size: 28rpx;
}
.card-total-num {
  color: #dc2626;
  font-weight: 600;
}

/* 人民币总计：放大字号+强化视觉 */
.total-amount {
  font-size: 58rpx;
  font-weight: 700;
  color: #dc2626;
  text-align: center;
  padding: 20rpx 0;
  line-height: 1.2;
  letter-spacing: 1.2rpx;
}

/* 空提示：更柔和的样式，和整体风格统一 */
.empty-tip {
  text-align: center;
  padding: 120rpx 0;
  color: #94a3b8;
  font-size: 28rpx;
  line-height: 1.5;
}

.empty-workspace {
  margin-top: 28rpx;
  padding: 42rpx 32rpx;
  text-align: center;
  background:
    radial-gradient(circle at top right, rgba(37, 99, 235, 0.12), transparent 28%),
    rgba(255, 255, 255, 0.94);
}

.empty-workspace-badge {
  display: inline-flex;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #eff6ff;
  color: #1d4ed8;
  font-size: 22rpx;
  font-weight: 700;
}

.empty-workspace-title {
  margin-top: 20rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
}

.empty-workspace-text {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #64748b;
}

.empty-workspace-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 26rpx;
}

.empty-workspace-btn {
  flex: 1;
  height: 78rpx;
  line-height: 78rpx;
  border-radius: 18rpx;
  background: #e8f0fb;
  color: #12314c;
  font-size: 24rpx;
  font-weight: 600;
  border: 1rpx solid #d8e4f3;
}

.empty-workspace-btn-primary {
  background: linear-gradient(135deg, #12314c, #175cd3);
  color: #ffffff;
  border: none;
}

.empty-workspace-links {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 24rpx;
  margin-top: 20rpx;
}

.empty-workspace-link {
  font-size: 24rpx;
  color: #175cd3;
}

/* 刷新按钮：和其他按钮统一圆角/动效 */
.refresh-btn {
  margin-top: 24rpx;
  background: #f1f5f9;
  color: #475569;
  border-radius: 12rpx;
  padding: 16rpx 0;
  font-size: 28rpx;
  transition: all 0.2s ease;
}
.refresh-btn:active {
  background: #e2e8f0;
  transform: scale(0.98);
}
.rate-actions {
  margin-top: 24rpx;
  display: flex;
  gap: 16rpx;
}

.rate-header-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.rate-actions .refresh-btn,
.rate-actions .stress-btn {
  margin-top: 0;
  flex: 1;
}
.stress-btn {
  background: #eaf8ef;
  color: #125d35;
  border: 1rpx solid #9dd9b6;
  border-radius: 12rpx;
  padding: 16rpx 0;
  font-size: 28rpx;
  transition: all 0.2s ease;
}
.stress-btn:active {
  background: #d9f0e2;
  transform: scale(0.98);
}

.stress-center {
  padding: 32rpx;
  margin-bottom: 24rpx;
  background: linear-gradient(180deg, #fff 0%, #f8fbff 100%);
  border-radius: 18rpx;
  box-shadow: 0 6rpx 20rpx rgba(15, 23, 42, 0.05);
}

.stress-center-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
}

.stress-title {
  margin-bottom: 8rpx;
}

.stress-subtitle {
  font-size: 24rpx;
  color: #64748b;
}

.stress-head-actions {
  display: flex;
  gap: 20rpx;
  flex-shrink: 0;
}

.stress-head-link {
  font-size: 24rpx;
  color: #1890ff;
}

.stress-result-box {
  margin-top: 24rpx;
  padding: 24rpx;
  background: #f8fafc;
  border-radius: 16rpx;
  border: 1rpx solid #e2e8f0;
}

.stress-result-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
}

.stress-result-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #0f172a;
}

.stress-result-time {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.stress-badge {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.stress-badge-up {
  color: #15803d;
  background: #e8f7ee;
}

.stress-badge-down {
  color: #b91c1c;
  background: #feeceb;
}

.stress-badge-flat {
  color: #475569;
  background: #e2e8f0;
}

.stress-metrics {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.stress-metric {
  flex: 1;
  padding: 18rpx;
  border-radius: 14rpx;
  background: #fff;
}

.stress-metric-label {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
  margin-bottom: 8rpx;
}

.stress-metric-value {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #0f172a;
}

.stress-metric-up {
  color: #15803d;
}

.stress-metric-down {
  color: #b91c1c;
}

.stress-metric-flat {
  color: #475569;
}

.stress-summary-line {
  margin-top: 20rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #475569;
}

.stress-impact-list {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.stress-impact-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #e2e8f0;
}

.stress-impact-item:last-child {
  border-bottom: none;
}

.stress-impact-code {
  font-size: 26rpx;
  color: #334155;
}

.stress-impact-value {
  font-size: 26rpx;
  font-weight: 600;
}

.stress-impact-up {
  color: #15803d;
}

.stress-impact-down {
  color: #b91c1c;
}

.stress-impact-flat {
  color: #475569;
}

.saved-scenario-section {
  margin-top: 24rpx;
}

.saved-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 16rpx;
}

.saved-scenario-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #e2e8f0;
}

.saved-scenario-item:last-child {
  border-bottom: none;
}

.saved-scenario-main {
  flex: 1;
}

.saved-scenario-name {
  font-size: 28rpx;
  color: #0f172a;
  font-weight: 600;
}

.saved-scenario-summary {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #64748b;
}

.saved-scenario-actions {
  display: flex;
  gap: 18rpx;
  flex-shrink: 0;
}

.saved-action {
  font-size: 24rpx;
  color: #1890ff;
}

.saved-action.danger {
  color: #dc2626;
}

.stress-editor-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(15, 23, 42, 0.45);
  display: flex;
  align-items: flex-end;
  z-index: 999;
}

.stress-editor-panel {
  width: 100%;
  max-height: 85vh;
  background: #fff;
  border-top-left-radius: 28rpx;
  border-top-right-radius: 28rpx;
  padding: 28rpx 28rpx 36rpx;
  box-sizing: border-box;
  overflow-y: auto;
}

.alert-editor-panel {
  max-height: 72vh;
}

.stress-editor-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.stress-editor-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
}

.stress-editor-tip {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.5;
}

.stress-editor-close {
  flex-shrink: 0;
  min-width: 108rpx;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #f8fafc;
  border: 1rpx solid #dbe3ee;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1;
  color: #475569;
  text-align: center;
  white-space: nowrap;
}

.stress-editor-close:active {
  opacity: 0.8;
  transform: translateY(2rpx);
}

.stress-editor-field {
  margin-top: 24rpx;
}

.stress-editor-label {
  font-size: 24rpx;
  color: #475569;
  margin-bottom: 10rpx;
}

.stress-editor-input {
  width: 100%;
  min-height: 84rpx;
  padding: 0 24rpx;
  border-radius: 14rpx;
  background: #f8fafc;
  border: 1rpx solid #dbe3ee;
  box-sizing: border-box;
}

.stress-editor-rows {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.stress-editor-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.stress-picker-wrap {
  flex: 1.4;
}

.stress-picker,
.stress-pct-input {
  min-height: 84rpx;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  border-radius: 14rpx;
  background: #f8fafc;
  border: 1rpx solid #dbe3ee;
  box-sizing: border-box;
  color: #0f172a;
}

.stress-pct-input {
  flex: 1;
}

.stress-row-remove {
