<view class="container {{lockScroll ? 'lock-scroll' : ''}}">
  <view class="custom-nav" style="height: {{navTotalHeight}}px; padding-top: {{navStatusHeight}}px;">
    <view class="custom-nav-inner" style="height: {{navContentHeight}}px;">
      <view class="custom-nav-side" style="width: {{navCapsuleSpace}}px;">
        <view class="custom-nav-back" bindtap="onNavBack">←</view>
      </view>
      <view class="custom-nav-title">{{navTitle}}</view>
      <view class="custom-nav-side custom-nav-side-right" style="width: {{navCapsuleSpace}}px;"></view>
    </view>
  </view>

  <view class="hero-card">
    <view class="hero-title-row">
      <view>
        <view class="hero-title">主页汇率工作台</view>
        <view class="hero-subtitle">决定首页显示哪些实时汇率，并支持拖拽排序和波动监测。</view>
      </view>
      <view class="hero-badge">{{showingRates.length}} 项展示中</view>
    </view>
    <view class="hero-actions">
      <button class="hero-action-btn hero-action-primary" bindtap="initAllRates">刷新实时汇率</button>
      <button class="hero-action-btn" bindtap="resetDefaultRates">恢复默认</button>
    </view>
    <view class="hero-tip">长按卡片后上下拖动可调整首页展示顺序，轻点卡片可移出首页。</view>
  </view>

  <view class="top-bar"></view>

  <view class="section">
    <view class="section-title">当前主页展示的汇率</view>
    <view class="section-subtitle">这些币种会直接出现在首页实时汇率卡片中。</view>
    <view class="card-list">
      <view 
        class="rate-card {{item.dragging ? 'dragging' : ''}}"
        wx:for="{{showingRates}}" 
        wx:key="code"
        data-index="{{index}}"
        data-code="{{item.code}}"
        bind:touchstart="onTouchStart"
        bind:touchmove="onTouchMove"
        bind:touchend="onTouchEnd"
        bind:touchcancel="onTouchCancel"
        bind:tap="onTapItem"
      >
        <view class="rate-info">
          <view style="display: flex; align-items: center; margin-bottom: 4rpx;">
            <text class="currency-code">{{item.code}}</text>
            <view 
              class="ai-monitor-tag" 
              catchtap="runAIMonitor" 
              data-code="{{item.code}}"
            >
              <text class="ai-icon">🧠</text>
              <text>AI监测</text>
            </view>
          </view>
          <text class="rate-value">1 {{item.code}} = ¥{{item.rate}}</text>
        </view>
        <text class="check-icon">✓</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title optional-title">可选添加至主页的汇率</view>
    <view class="section-subtitle">点击即可加入首页展示，不会影响实时汇率数据源。</view>
    <view class="card-list">
      <view 
        class="rate-card"
        wx:for="{{optionalRates}}" 
        wx:key="code"
        bindtap="addToShow"
        data-code="{{item.code}}"
      >
        <view class="rate-info">
          <text class="currency-code">{{item.code}}</text>
          <text class="rate-value">1 {{item.code}} = ¥{{item.rate}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="custom-toast" wx:if="{{toastVisible}}">
    <text class="icon" wx:if="{{toastIcon === 'success'}}">✓</text>
    <text class="text">{{toastText}}</text>
  </view>
</view>
