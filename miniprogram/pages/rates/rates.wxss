/* 全局page：固定高度，作为容器滚动的基础 */
page {
  height: 100vh;
  margin: 0;
  padding: 0;
  background-color: #f5f5f5;
  overflow: hidden; /* 全局层先锁，让容器单独滚动 */
}
/* 主容器：轻扫时正常滚动，长按锁定 */
.container {
  box-sizing: border-box;
  padding: 22rpx 24rpx 40rpx;
  height: 100vh;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch; /* 真机顺滑滚动必加 */
  transition: overflow 0s; /* 锁定/解锁无延迟，瞬间生效 */
}
/* 🔴 长按锁定核心样式：直接锁死容器滚动，优先级最高 */
.container.lock-scroll {
  overflow-y: hidden !important;
  pointer-events: none !important; /* 屏蔽容器所有触摸事件，防止滚动 */
}
/* 🔴 拖拽卡片单独放开事件：只让拖拽卡片能响应触摸，页面其他地方全锁 */
.container.lock-scroll .rate-card.dragging {
  pointer-events: auto !important;
}
/* 顶部栏：保留你调好的样式，完全收掉 */
.top-bar {
  height: 0;
  padding: 0;
  margin: 0;
}
.hero-card {
  margin-bottom: 24rpx;
  padding: 30rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #0f172a, #1d4ed8 52%, #22c55e);
  box-shadow: 0 20rpx 44rpx rgba(15, 23, 42, 0.16);
  color: #ffffff;
}
.hero-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}
.hero-title {
  font-size: 38rpx;
  font-weight: 700;
}
.hero-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.76);
}
.hero-badge {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  font-size: 22rpx;
}
.hero-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 22rpx;
}
.hero-action-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.12);
  color: #ffffff;
  font-size: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.18);
}
.hero-action-primary {
  background: #ffffff;
  color: #102a43;
}
.hero-tip {
  margin-top: 16rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.76);
}
/* 区块+标题：保留紧凑间距、对称对齐 */
.section {
  margin-bottom: 24rpx;
}
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin: 0 0 16rpx 0;
}
.optional-title {
  font-weight: 400;
  color: #666;
  margin: 24rpx 0 16rpx 0;
}
.section-subtitle {
  margin: -4rpx 0 16rpx;
  font-size: 23rpx;
  line-height: 1.6;
  color: #64748b;
}
/* 卡片列表：保留紧凑间距 */
.card-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  box-sizing: border-box;
}
/* 汇率卡片+拖拽浮起样式：完全保留你调好的效果 */
.rate-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: rgba(255, 255, 255, 0.94);
  border-radius: 20rpx;
  padding: 24rpx 30rpx;
  box-shadow: 0 12rpx 24rpx rgba(15, 23, 42, 0.05);
  box-sizing: border-box;
  width: 100%;
  transition: all 0.2s ease;
  position: relative;
  z-index: 1;
}
.rate-card.dragging {
  transform: scale(1.02);
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.1);
  background: #f9fcff;
  z-index: 99; /* 提高层级，确保拖拽时在最上层 */
}
/* 卡片内部文字：样式不变 */
.rate-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  width: 85%;
}
.currency-code {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}
.ai-monitor-tag {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  margin-left: 12rpx;
  padding: 2rpx 12rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #125d35;
  background: #eaf8ef;
  border: 1rpx solid #9dd9b6;
}
.ai-icon {
  font-size: 22rpx;
}
.rate-value {
  font-size: 26rpx;
  color: #666;
  white-space: nowrap;
}
.check-icon {
  font-size: 32rpx;
  color: #1890ff;
  font-weight: 700;
  width: 40rpx;
  text-align: right;
}
/* 自定义提示框：样式不变 */
.custom-toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0,0,0,0.7);
  color: #fff;
  border-radius: 12rpx;
  padding: 30rpx 40rpx;
  z-index: 9999;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  min-width: 280rpx;
}
.custom-toast .icon {
  font-size: 50rpx;
  color: #fff;
}
.custom-toast .text {
  font-size: 28rpx;
  text-align: center;
  white-space: pre-wrap;
  line-height: 1.4;
}

/* Liquid Glass Harmonization */
page,
.container {
  background:
    radial-gradient(circle at 10% -10%, rgba(143, 244, 120, 0.18) 0%, rgba(143, 244, 120, 0) 28%),
    radial-gradient(circle at 90% -8%, rgba(145, 214, 255, 0.2) 0%, rgba(145, 214, 255, 0) 28%),
    linear-gradient(170deg, #f8fbff 0%, #edf1f8 100%);
}

.hero-card,
.rate-card,
.section,
.custom-toast {
  border: 1rpx solid rgba(255, 255, 255, 0.56);
  backdrop-filter: blur(14rpx) saturate(1.14);
  -webkit-backdrop-filter: blur(14rpx) saturate(1.14);
}

.hero-action-primary {
  background: linear-gradient(140deg, #151d2f, #0c1324);
  color: #ffffff;
}

/* System polish */
.hero-card,
.rate-card,
.section,
.custom-toast {
  border-radius: 24rpx;
}

.hero-title,
.section-title,
.currency-code {
  letter-spacing: 0.2rpx;
}

/* Liquid Glass Unified Final Override */
page,
.container {
  background:
    radial-gradient(circle at 12% -8%, rgba(255, 255, 255, 0.4) 0%, rgba(255, 255, 255, 0) 30%),
    radial-gradient(circle at 90% 6%, rgba(214, 194, 168, 0.22) 0%, rgba(214, 194, 168, 0) 30%),
    linear-gradient(180deg, #f6f4f1 0%, #f1eee9 100%) !important;
}

.hero-card,
.rate-card,
.section,
.custom-toast {
  background: linear-gradient(154deg, rgba(255, 255, 255, 0.74), rgba(247, 241, 233, 0.56)) !important;
  border: 1rpx solid rgba(255, 255, 255, 0.72) !important;
  backdrop-filter: blur(14rpx) saturate(1.03);
  -webkit-backdrop-filter: blur(14rpx) saturate(1.03);
  box-shadow: 0 10rpx 24rpx rgba(66, 53, 39, 0.09) !important;
}

.hero-action-primary {
  background: linear-gradient(140deg, #7a6348, #5f4d39) !important;
  color: #fff8ef !important;
  border-color: rgba(255, 255, 255, 0.42) !important;
}

/* Spacing Polish: improve text paddings and rhythm */
.hero-card {
  padding: 30rpx 28rpx 24rpx !important;
}

.hero-title {
  line-height: 1.28;
}

.hero-subtitle {
  margin-top: 12rpx;
  line-height: 1.62;
}

.hero-tip {
  margin-top: 18rpx;
  line-height: 1.62;
}

.section {
  padding: 22rpx 22rpx 20rpx !important;
}

.section-title {
  margin: 0 2rpx 10rpx 2rpx !important;
  line-height: 1.32;
}

.optional-title {
  margin: 0 2rpx 10rpx 2rpx !important;
  font-weight: 600;
}

.section-subtitle {
  margin: 0 2rpx 14rpx 2rpx !important;
  line-height: 1.62;
}

.card-list {
  margin-top: 4rpx;
}

.rate-card {
  padding: 24rpx 26rpx !important;
}

.rate-info {
  gap: 10rpx;
}

.currency-code {
  line-height: 1.2;
}

.rate-value {
  line-height: 1.5;
}

/* Liquid Glass Main Inspired Finish */
page,
.container {
  background:
    radial-gradient(circle at 14% -10%, rgba(255, 255, 255, 0.46) 0%, rgba(255, 255, 255, 0) 32%),
    radial-gradient(circle at 90% 8%, rgba(220, 198, 170, 0.22) 0%, rgba(220, 198, 170, 0) 30%),
    linear-gradient(180deg, #f6f4f1 0%, #f1eee9 100%) !important;
}

.hero-card,
.rate-card,
.section,
.custom-toast {
  background: linear-gradient(160deg, rgba(255, 255, 255, 0.84), rgba(243, 235, 226, 0.58)) !important;
  border: 1rpx solid rgba(255, 255, 255, 0.78) !important;
  box-shadow: 0 8rpx 18rpx rgba(0, 0, 0, 0.16), 0 -16rpx 28rpx inset rgba(0, 0, 0, 0.08), 0 1rpx 0 inset rgba(255, 255, 255, 0.78) !important;
  backdrop-filter: blur(16rpx) contrast(1.12) brightness(1.03) saturate(1.08);
  -webkit-backdrop-filter: blur(16rpx) contrast(1.12) brightness(1.03) saturate(1.08);
}