}

.security-eye {
  position: relative;
  width: 30rpx;
  height: 18rpx;
  border: 2rpx solid #4f6888;
  border-radius: 24rpx / 14rpx;
  background: radial-gradient(circle at 50% 50%, #f8fbff 0%, #edf3fb 70%, #e5edf8 100%);
  overflow: hidden;
}

.security-eye-iris {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 35%, #8fb3dc 0%, #5f84b3 60%, #4f6888 100%);
  transform: translate(-50%, -50%);
}

.security-eye-pupil {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 5rpx;
  height: 5rpx;
  background: #2d4461;
  border-radius: 50%;
  transform: translate(-50%, -50%);
}

.security-eye-glint {
  position: absolute;
  top: 4rpx;
  left: 14rpx;
  width: 4rpx;
  height: 4rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.95);
}

.security-eye-off {
  opacity: 0.6;
}

.security-eye-strike {
  position: absolute;
  top: 50%;
  left: -3rpx;
  width: 36rpx;
  height: 2rpx;
  background: linear-gradient(90deg, #3f5776, #5a7396);
  border-radius: 999rpx;
  transform: rotate(-28deg);
  z-index: 2;
}

