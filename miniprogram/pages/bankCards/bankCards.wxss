.hero-meta-item,
.hero-meta-dot,
.hero-total-label,
.hero-insight-label,
.hero-insight-note,
.summary-label,
.currency-amount,
.currency-cny,
.planner-row-meta,
.timeline-meta,
.rebalance-meta,
.order-meta,
.order-note,
.empty-text,
.visual-subtitle,
.shock-tip,
.forecast-label,
.editor-label,
.hero-shortcut-pill-idle {
  color: rgba(96, 82, 66, 0.74);
}

.hero-insight-strip {
  border-top: 1rpx solid rgba(198, 182, 161, 0.34);
  border-bottom: 1rpx solid rgba(198, 182, 161, 0.34);
}

.hero-insight-divider {
  background: rgba(198, 182, 161, 0.3);
}

.hero-btn,
.editor-btn,
.empty-btn {
  background: linear-gradient(148deg, rgba(255, 255, 255, 0.62), rgba(242, 234, 224, 0.42));
  border: 1rpx solid rgba(255, 255, 255, 0.78);
  color: #5f4d39;
  box-shadow: 0 8rpx 18rpx rgba(58, 46, 33, 0.08);
}

.hero-btn-primary,
.editor-btn:not(.editor-btn-ghost),
.empty-btn {
  background: linear-gradient(145deg, #7f6750, #6b5643);
  color: #fff5ea;
  border-color: rgba(255, 255, 255, 0.42);
}

.hero-btn-ghost,
.editor-btn-ghost {
  background: linear-gradient(148deg, rgba(255, 255, 255, 0.56), rgba(239, 230, 218, 0.36));
  color: #67523d;
}

.hero-shortcut-pill-active {
  background: linear-gradient(148deg, rgba(248, 242, 234, 0.66), rgba(237, 228, 215, 0.46));
  color: #66503a;
}

.security-eye-btn {
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.64), rgba(241, 233, 223, 0.44));
  border-color: rgba(255, 255, 255, 0.78);
}

.security-eye {
  border-color: #7b654b;
  background: radial-gradient(circle at 50% 50%, #fdf9f3 0%, #f5ece0 72%, #ece1d2 100%);
}

.security-eye-iris {
  background: radial-gradient(circle at 35% 35%, #d2b089 0%, #aa845a 62%, #7b654b 100%);
}

.security-eye-pupil {
  background: #5f4a34;
}

.security-eye-strike {
  background: linear-gradient(90deg, #745d43, #92745a);
}

/* FX Order Module Polish */
.order-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.order-item {
  padding: 20rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.74);
  background: linear-gradient(154deg, rgba(255, 255, 255, 0.72), rgba(243, 236, 227, 0.56));
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.58), 0 8rpx 18rpx rgba(60, 48, 36, 0.07);
}

.order-top {
  align-items: flex-start;
}

.order-title {
  color: #4a3b2e;
}

.order-meta,
.order-note {
  color: rgba(96, 82, 66, 0.78);
}

.order-side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.order-status {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  border: 1rpx solid #deceb8;
  background: linear-gradient(148deg, rgba(247, 241, 232, 0.82), rgba(237, 226, 210, 0.64));
  color: #6d563d;
  font-weight: 700;
}

.order-delete {
  margin-top: 0;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  border: 1rpx solid #e7d5c4;
  background: rgba(255, 255, 255, 0.68);
  color: #8e6d4c;
}

.order-stage {
  margin-top: 12rpx;
  border: 1rpx solid #e5d8c8;
  background: linear-gradient(150deg, rgba(255, 255, 255, 0.66), rgba(241, 233, 222, 0.5));
  color: #5f4e3b;
}

.order-stage-status {
  color: #7f6a51;
}

.order-stage-hit {
  color: #9a6b34;
}

/* FX Order Roundness Refinement */
.fx-order-card {
  border-radius: 28rpx;
}

.fx-order-card .order-list {
  padding: 10rpx;
  border-radius: 22rpx;
  background: linear-gradient(154deg, rgba(255, 255, 255, 0.46), rgba(240, 231, 219, 0.34));
  border: 1rpx solid rgba(255, 255, 255, 0.68);
}

.fx-order-card .order-item {
  border-radius: 22rpx;
  overflow: hidden;
}

.fx-order-card .order-stage {
  border-radius: 14rpx;
}

.fx-order-card .order-status,
.fx-order-card .order-delete {
  border-radius: 999rpx;
}

/* Liquid Glass Unified Final Override */
.page {
  background:
    radial-gradient(circle at 12% -8%, rgba(255, 255, 255, 0.4) 0%, rgba(255, 255, 255, 0) 30%),
    radial-gradient(circle at 90% 6%, rgba(214, 194, 168, 0.22) 0%, rgba(214, 194, 168, 0) 30%),
    linear-gradient(180deg, #f6f4f1 0%, #f1eee9 100%) !important;
}

.hero,
.card,
.summary-box,
.insight,
.risk-band-card,
.currency-card,
.visual-card,
.shock-card,
.planner-card,
.bank-card,
.empty,
.editor-panel,
.rebalance-list,
.order-list,
.timeline-list,
.planner-list-block,
.maturity-box,
.visual-placeholder,
.shock-alert-box,
.rebalance-item,
.order-item,
.planner-row,
.timeline-item,
.editor-field,
.forecast-box {
  background: linear-gradient(154deg, rgba(255, 255, 255, 0.74), rgba(247, 241, 233, 0.56)) !important;
  border: 1rpx solid rgba(255, 255, 255, 0.72) !important;
  backdrop-filter: blur(14rpx) saturate(1.03);
  -webkit-backdrop-filter: blur(14rpx) saturate(1.03);
  box-shadow: 0 10rpx 24rpx rgba(66, 53, 39, 0.09) !important;
}

.hero-btn,
.hero-btn-primary,
.hero-btn-ghost,
.editor-btn,
.editor-btn-ghost,
.empty-btn,
.hero-shortcut-pill,
.hero-shortcut-eye .security-eye-btn,
.section-link,
.bank-card-link,
.order-delete,
.order-status {
  background: linear-gradient(148deg, rgba(255, 255, 255, 0.82), rgba(243, 234, 224, 0.64)) !important;
  border: 1rpx solid rgba(255, 255, 255, 0.74) !important;
  color: #63513d !important;
}

.hero-btn-primary,
.editor-btn:not(.editor-btn-ghost),
.empty-btn {
  background: linear-gradient(140deg, #7a6348, #5f4d39) !important;
  color: #fff8ef !important;
  border-color: rgba(255, 255, 255, 0.42) !important;
}

/* Liquid Glass Main Inspired Finish */
.page {
  background:
    radial-gradient(circle at 14% -10%, rgba(255, 255, 255, 0.46) 0%, rgba(255, 255, 255, 0) 32%),
    radial-gradient(circle at 90% 8%, rgba(220, 198, 170, 0.22) 0%, rgba(220, 198, 170, 0) 30%),
    linear-gradient(180deg, #f6f4f1 0%, #f1eee9 100%) !important;
}

.hero,
.card,
.summary-box,
.insight,
.risk-band-card,
.currency-card,
.visual-card,
.shock-card,
.planner-card,
.bank-card,
.empty,
.editor-panel,
.rebalance-list,
.order-list,
.timeline-list,
.planner-list-block,
.maturity-box,
.visual-placeholder,
.shock-alert-box,
.rebalance-item,
.order-item,
.planner-row,
.timeline-item,
.editor-field,
.forecast-box {
  background: linear-gradient(160deg, rgba(255, 255, 255, 0.84), rgba(243, 235, 226, 0.58)) !important;
  border: 1rpx solid rgba(255, 255, 255, 0.78) !important;
  box-shadow: 0 8rpx 18rpx rgba(0, 0, 0, 0.16), 0 -16rpx 28rpx inset rgba(0, 0, 0, 0.08), 0 1rpx 0 inset rgba(255, 255, 255, 0.78) !important;
  backdrop-filter: blur(16rpx) contrast(1.12) brightness(1.03) saturate(1.08);
  -webkit-backdrop-filter: blur(16rpx) contrast(1.12) brightness(1.03) saturate(1.08);
}

/* Delete text should always be red */
.order-delete,
.fx-order-card .order-delete,
.bank-card-link.danger {
  color: #d84444 !important;
}
