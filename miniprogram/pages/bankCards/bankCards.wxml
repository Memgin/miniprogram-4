<view class="page">
  <view class="hero hero-{{dashboardTone}}">
    <view class="hero-main">
      <view class="hero-main-left">
        <view class="hero-title">银行卡账户</view>
        <view class="hero-meta-row">
          <text class="hero-meta-item">{{cardCount}} 张卡</text>
          <text class="hero-meta-dot">·</text>
          <text class="hero-meta-item">{{currencyAccountCount}} 个账户</text>
        </view>
      </view>
      <view class="hero-total-wrap">
        <view class="hero-total-label">总资产</view>
        <view class="hero-total-value">{{privacyMode ? '***' : '¥' + totalCny}}</view>
      </view>
    </view>

    <view class="hero-insight-strip" wx:if="{{cardCount > 0}}">
      <view class="hero-insight-box">
        <view class="hero-insight-label">头部银行卡</view>
        <view class="hero-insight-value">{{topCardName}}</view>
        <view class="hero-insight-note">{{privacyMode ? '金额已隐藏' : topCardValueText}}</view>
      </view>
      <view class="hero-insight-divider"></view>
      <view class="hero-insight-box">
        <view class="hero-insight-label">平均单卡资产</view>
        <view class="hero-insight-value">{{privacyMode ? '***' : averageAssetText}}</view>
        <view class="hero-insight-note">{{cardCount}} 张卡参与统计</view>
      </view>
    </view>

    <view class="hero-actions">
      <button class="hero-btn hero-btn-primary" bindtap="gotoAddCard">新增银行卡</button>
      <button class="hero-btn hero-btn-ghost" bindtap="gotoDiagnostics">诊断中心</button>
      <view class="hero-eye-toggle" bindtap="togglePrivacyMode" aria-label="切换金额显示">
        <view class="hero-eye hero-eye-{{privacyMode ? 'off' : 'on'}}">
          <view class="hero-eye-pupil"></view>
          <view class="hero-eye-strike" wx:if="{{privacyMode}}"></view>
        </view>
      </view>
    </view>

    <view class="hero-shortcuts" wx:if="{{cardCount > 0}}">
      <view class="hero-shortcut-pill" bindtap="gotoExport">导出资产</view>
      <view class="hero-shortcut-pill" bindtap="copyBankSummary">复制摘要</view>
      <view class="hero-shortcut-pill hero-shortcut-pill-{{biometricEnabled ? 'active' : 'idle'}}" bindtap="toggleBiometricEnabled">{{biometricEnabled ? 'Bio On' : 'Bio Off'}}</view>
    </view>
  </view>

  <view class="summary-grid">
    <view class="summary-box card summary-box-strong">
      <view class="summary-label">银行卡数量</view>
      <view class="summary-value">{{cardCount}}</view>
    </view>
    <view class="summary-box card">
      <view class="summary-label">币种账户数</view>
      <view class="summary-value">{{currencyAccountCount}}</view>
    </view>
    <view class="summary-box card">
      <view class="summary-label">覆盖币种</view>
      <view class="summary-value">{{uniqueCurrencyCount}}</view>
    </view>
    <view class="summary-box card">
      <view class="summary-label">人民币总计</view>
      <view class="summary-value">{{privacyMode ? '***' : '¥' + totalCny}}</view>
    </view>
  </view>

  <view class="insight card" wx:if="{{cardCount > 0}}">
    <view class="insight-title">最大外币敞口</view>
    <view class="insight-text">{{privacyMode ? '金额已隐藏' : topCurrencyExposureText}}</view>
  </view>

  <view class="risk-band-card card" wx:if="{{cardCount > 0}}">
    <view class="section-head compact-head">
      <view class="section-title">风险预警带</view>
      <view class="risk-band-badge risk-band-badge-{{dashboardTone}}">{{riskBandLabel}}</view>
    </view>
    <view class="risk-band-track">
      <view class="risk-band-segment risk-band-safe"></view>
      <view class="risk-band-segment risk-band-watch"></view>
      <view class="risk-band-segment risk-band-alert"></view>
      <view class="risk-band-marker" style="left: {{riskBandLeft}};"></view>
    </view>
    <view class="risk-band-meta">
      <text>安全</text>
      <text>关注</text>
      <text>高风险</text>
    </view>
    <view class="risk-band-summary">{{riskBandSummary}}</view>
    <view class="risk-driver-list">
      <view class="risk-driver-pill" wx:for="{{riskBandDrivers}}" wx:key="*this">{{item}}</view>
    </view>
  </view>

  <view class="currency-card card" wx:if="{{currencySummary.length > 0}}">
    <view class="section-head currency-section-head">
      <view class="section-title">各币种总余额</view>
      <view class="section-pill">{{currencySummary.length}} 项</view>
    </view>
    <view class="currency-list">
      <view class="currency-row" wx:for="{{currencySummary}}" wx:key="code">
        <view class="currency-code">{{item.code}}</view>
        <view class="currency-amount">{{privacyMode ? '***' : (item.code + ': ' + item.totalAmount)}}</view>
        <view class="currency-cny">{{privacyMode ? '***' : ('≈ ¥' + item.cnyAmount)}}</view>
      </view>
    </view>
  </view>

  <view class="visual-card card" wx:if="{{cardCount > 0}}">
    <view class="section-head compact-head">
      <view class="section-title">资产热力矩阵</view>
      <view class="section-pill">卡 x 币种</view>
    </view>
    <view class="visual-subtitle">颜色越深，表示该银行卡在该币种上的人民币敞口越大。</view>
    <view class="visual-placeholder" wx:if="{{privacyMode}}">隐私模式下已隐藏资产热力矩阵</view>
    <scroll-view wx:else scroll-x class="heatmap-scroll">
      <view class="heatmap-board">
        <view class="heatmap-header-row">
          <view class="heatmap-side-head">币种</view>
          <view class="heatmap-card-head" wx:for="{{heatmapXAxis}}" wx:key="*this">{{item}}</view>
        </view>
        <view class="heatmap-data-row" wx:for="{{heatmapRows}}" wx:key="code">
          <view class="heatmap-side-code">{{item.code}}</view>
          <view class="heatmap-cell" wx:for="{{item.cells}}" wx:key="cardId" style="{{item.style}}">{{item.value > 0 ? item.valueText : '-'}}</view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="visual-card card" wx:if="{{cardCount > 0}}">
    <view class="section-head compact-head">
      <view class="section-title">资金流向图</view>
      <view class="section-pill">总资产 → 银行卡 → 币种</view>
    </view>
    <view class="visual-subtitle">看清人民币总资产是如何分解到各张卡和各类外币上的。</view>
    <view class="visual-placeholder" wx:if="{{privacyMode}}">隐私模式下已隐藏资金流向图</view>
    <view wx:else class="flow-board">
      <view class="flow-column">
        <view class="flow-column-title">总资产流向银行卡</view>
        <view class="flow-row" wx:for="{{fundsFlowCards}}" wx:key="id">
          <view class="flow-topline">
            <text class="flow-name">{{item.name}}</text>
            <text class="flow-value">{{item.valueText}}</text>
          </view>
          <view class="flow-bar-track">
            <view class="flow-bar-fill" style="width: {{item.width}};"></view>
          </view>
        </view>
      </view>
      <view class="flow-divider-arrow">→</view>
      <view class="flow-column">
        <view class="flow-column-title">银行卡流向币种</view>
        <view class="flow-row" wx:for="{{fundsFlowCurrencies}}" wx:key="code">
          <view class="flow-topline">
            <text class="flow-name">{{item.code}}</text>
            <text class="flow-value">{{item.valueText}}</text>
          </view>
          <view class="flow-bar-track flow-bar-track-currency">
            <view class="flow-bar-fill flow-bar-fill-currency" style="width: {{item.width}};"></view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="shock-card card" wx:if="{{shockCurrencyOptions.length > 0}}">
    <view class="section-head compact-head">
      <view class="section-title">汇率冲击沙盘</view>
      <view class="section-pill">实时预演</view>
    </view>
    <view class="shock-toolbar">
      <picker class="shock-picker-wrap" mode="selector" range="{{shockCurrencyLabels}}" value="{{shockCodeIndex}}" bindchange="onShockCurrencyChange">
        <view class="shock-picker">{{shockCurrencyLabels[shockCodeIndex]}}</view>
      </picker>
      <view class="shock-badge">{{shockPctText}}</view>
    </view>
    <slider min="-15" max="15" step="1" value="{{shockPct}}" activeColor="#2563eb" backgroundColor="#dbeafe" bindchanging="onShockSliderChange" bindchange="onShockSliderChange" />
    <view class="shock-tip">模拟所选币种相对人民币发生汇率冲击后的资产变化。</view>

    <view class="shock-summary" wx:if="{{shockImpactSummary}}">
      <view class="shock-summary-box">
        <view class="shock-summary-label">币种冲击</view>
        <view class="shock-summary-value">{{shockImpactSummary.code}} {{shockImpactSummary.pctText}}</view>
      </view>
      <view class="shock-summary-box">
        <view class="shock-summary-label">组合变化</view>
        <view class="shock-summary-value">{{privacyMode ? '***' : shockImpactSummary.deltaText}}</view>
      </view>
      <view class="shock-summary-box">
        <view class="shock-summary-label">冲击后总资产</view>
        <view class="shock-summary-value">{{privacyMode ? '***' : shockImpactSummary.nextTotalText}}</view>
      </view>
    </view>

    <view class="shock-impact-list" wx:if="{{shockImpactedCards.length > 0}}">
      <view class="shock-impact-item" wx:for="{{shockImpactedCards}}" wx:key="id">
        <view class="shock-impact-top">
          <text class="shock-impact-name">{{item.name}}</text>
          <text class="shock-impact-delta shock-impact-{{item.tone}}">{{privacyMode ? '***' : item.deltaText}}</text>
        </view>
        <view class="shock-impact-bar">
          <view class="shock-impact-fill shock-impact-fill-{{item.tone}}" style="width: {{item.barWidth}};"></view>
        </view>
        <view class="shock-impact-meta">基准敞口 {{privacyMode ? '***' : item.exposureText}} · 冲击后 {{privacyMode ? '***' : item.nextValueText}}</view>
      </view>
    </view>

    <view class="shock-alert-box" wx:if="{{shockAlertHits.length > 0}}">
      <view class="shock-alert-title">可能受影响的提醒</view>
      <view class="shock-alert-line" wx:for="{{shockAlertHits}}" wx:key="id">{{item.note}} · {{item.directionText}} {{item.thresholdText}}</view>
    </view>
  </view>

  <view class="planner-card card" wx:if="{{rebalanceSummary}}">
    <view class="section-head compact-head">
      <view class="section-title">智能调仓建议</view>
      <view class="section-pill">{{rebalanceSummary.modeLabel}}</view>
    </view>
    <view class="planner-subtitle">{{rebalanceSummary.headline}}</view>
    <view class="planner-highlight">目标结构：{{rebalanceSummary.targetMixText}}</view>
    <view class="planner-tip">{{rebalanceSummary.bufferText}}</view>
    <view class="rebalance-list">
      <view class="rebalance-item" wx:for="{{rebalanceActions}}" wx:key="code">
        <view class="rebalance-top">
          <view class="rebalance-code">{{item.code}}</view>
          <view class="rebalance-delta rebalance-delta-{{item.tone}}">{{item.deltaText}}</view>
        </view>
        <view class="rebalance-meta">当前 {{item.currentWeightText}} → 目标 {{item.targetWeightText}}</view>
        <view class="rebalance-amount">{{item.amountText}}</view>
        <view class="rebalance-reason">{{item.reason}}</view>
      </view>
    </view>
  </view>

  <view class="planner-card card">
    <view class="section-head compact-head">
      <view class="section-title">条件单与分批换汇</view>
      <view class="section-link" bindtap="openFxOrderEditor">新增计划</view>
    </view>
    <view class="planner-subtitle">把提醒升级为执行计划，按目标汇率自动拆分为多笔操作。</view>

    <view class="planner-empty" wx:if="{{fxOrderPlans.length === 0}}">还没有换汇计划，先添加一条目标汇率和预算。</view>
    <view class="order-list" wx:else>
      <view class="order-item" wx:for="{{fxOrderPlans}}" wx:key="id">
        <view class="order-top">
          <view>
            <view class="order-title">{{item.code}} · {{item.directionText}}</view>
            <view class="order-meta">当前 {{item.currentRateText}} · 目标 {{item.targetRateText}} · 总预算 {{item.totalBudgetText}}</view>
          </view>
          <view class="order-side">
            <view class="order-status">{{item.planStatus}}</view>
            <text class="order-delete" bindtap="deleteFxOrderPlan" data-id="{{item.id}}">删除</text>
          </view>
        </view>
        <view class="order-note" wx:if="{{item.note}}">{{item.note}}</view>
        <view class="order-stage" wx:for="{{item.stages}}" wx:key="label">
          <text>{{item.label}}</text>
          <text>目标 {{item.rateText}}</text>
          <text>{{item.budgetText}}</text>
          <text class="order-stage-status {{item.triggered ? 'order-stage-hit' : ''}}">{{item.statusText}}</text>
        </view>
      </view>
    </view>

    <view class="editor-panel" wx:if="{{showFxOrderEditor}}">
      <view class="editor-grid">
        <view class="editor-field">
          <view class="editor-label">币种</view>
          <picker mode="selector" range="{{plannerCurrencyLabels}}" bindchange="onFxOrderCodeChange">
            <view class="editor-picker">{{fxOrderForm.code}}</view>
          </picker>
        </view>
        <view class="editor-field">
          <view class="editor-label">方向</view>
          <picker mode="selector" range="{{fxDirectionLabels}}" bindchange="onFxOrderDirectionChange">
            <view class="editor-picker">{{fxOrderForm.direction === 'above' ? '高于目标分批止盈' : '低于目标分批买入'}}</view>
          </picker>
        </view>
        <view class="editor-field">
          <view class="editor-label">目标汇率</view>
          <input class="editor-input" type="digit" value="{{fxOrderForm.targetRate}}" data-field="targetRate" bindinput="onFxOrderFieldInput" placeholder="例如 7.1800" />
        </view>
        <view class="editor-field">
          <view class="editor-label">总预算 CNY</view>
          <input class="editor-input" type="digit" value="{{fxOrderForm.totalBudgetCny}}" data-field="totalBudgetCny" bindinput="onFxOrderFieldInput" placeholder="例如 10000" />
        </view>
        <view class="editor-field">
          <view class="editor-label">分批笔数</view>
          <input class="editor-input" type="number" value="{{fxOrderForm.trancheCount}}" data-field="trancheCount" bindinput="onFxOrderFieldInput" placeholder="1-5" />
        </view>
        <view class="editor-field">
          <view class="editor-label">阶梯间距 %</view>
          <input class="editor-input" type="digit" value="{{fxOrderForm.stepPct}}" data-field="stepPct" bindinput="onFxOrderFieldInput" placeholder="例如 0.6" />
        </view>
      </view>
      <view class="editor-field editor-field-full">
        <view class="editor-label">备注</view>
        <input class="editor-input" value="{{fxOrderForm.note}}" data-field="note" bindinput="onFxOrderFieldInput" placeholder="例如 学费换汇 / 差旅备用" />
      </view>
      <view class="editor-actions">
        <view class="editor-btn editor-btn-ghost" bindtap="closeFxOrderEditor">取消</view>
        <view class="editor-btn" bindtap="saveFxOrderPlan">保存计划</view>
      </view>
    </view>
  </view>

  <view class="planner-card card">
    <view class="section-head compact-head">
      <view class="section-title">现金流与到期预测</view>
      <view class="range-tabs">
        <view class="range-tab {{forecastRangeIndex === index ? 'range-tab-active' : ''}}" wx:for="{{forecastRangeOptions}}" wx:key="*this" data-index="{{index}}" bindtap="selectForecastRange">{{item}}天</view>
      </view>
    </view>
    <view class="planner-subtitle">统一看未来现金流、定存到期回款和预测后的资产位置。</view>

    <view class="forecast-grid" wx:if="{{forecastSummary}}">
      <view class="forecast-box">
        <view class="forecast-label">期间流入</view>
        <view class="forecast-value">{{privacyMode ? '***' : forecastSummary.inflowText}}</view>
      </view>
      <view class="forecast-box">
        <view class="forecast-label">期间流出</view>
        <view class="forecast-value">{{privacyMode ? '***' : forecastSummary.outflowText}}</view>
      </view>
      <view class="forecast-box">
        <view class="forecast-label">净变化</view>
        <view class="forecast-value">{{privacyMode ? '***' : forecastSummary.netText}}</view>
      </view>
      <view class="forecast-box forecast-box-strong">
        <view class="forecast-label">预测资产</view>
        <view class="forecast-value">{{privacyMode ? '***' : forecastSummary.projectedText}}</view>
      </view>
    </view>

    <view class="planner-highlight" wx:if="{{forecastSummary}}">最近到期：{{privacyMode ? '***' : forecastSummary.nextMaturityText}}</view>

    <view class="planner-actions-row">
      <view class="section-link" bindtap="openCashflowEditor">新增现金流</view>
      <view class="section-link" bindtap="openMaturityEditor">新增到期计划</view>
    </view>

    <view class="timeline-list" wx:if="{{forecastTimeline.length > 0}}">
      <view class="timeline-item" wx:for="{{forecastTimeline}}" wx:key="id">
        <view>
          <view class="timeline-title">{{item.title}} · {{item.date}}</view>
          <view class="timeline-meta">{{item.typeText}} · {{item.note}}</view>
        </view>
        <view class="timeline-value timeline-value-{{item.tone}}">{{privacyMode ? '***' : item.valueText}}</view>
      </view>
    </view>
    <view class="planner-empty" wx:else>当前预测窗口内还没有现金流或到期事件。</view>

    <view class="maturity-box" wx:if="{{maturityHighlights.length > 0}}">
      <view class="maturity-title">到期高亮</view>
      <view class="maturity-line" wx:for="{{maturityHighlights}}" wx:key="id">{{item.date}} · {{item.title}} · {{privacyMode ? '***' : item.valueText}}</view>
    </view>

    <view class="planner-list-block" wx:if="{{cashflowPlans.length > 0}}">
      <view class="planner-list-title">现金流计划</view>
      <view class="planner-row" wx:for="{{cashflowPlans}}" wx:key="id">
        <view>
          <view class="planner-row-title">{{item.name}}</view>
          <view class="planner-row-meta">{{item.typeText}} · {{item.amountText}} · {{item.dueDate}} · {{item.frequencyText}}</view>
        </view>
        <text class="order-delete" bindtap="deleteCashflowPlan" data-id="{{item.id}}">删除</text>
      </view>
    </view>

    <view class="planner-list-block" wx:if="{{maturityPlans.length > 0}}">
      <view class="planner-list-title">到期计划</view>
      <view class="planner-row" wx:for="{{maturityPlans}}" wx:key="id">
        <view>
          <view class="planner-row-title">{{item.name}}</view>
          <view class="planner-row-meta">{{item.principalText}} · {{item.maturityDate}} · {{item.aprText}}</view>
        </view>
        <text class="order-delete" bindtap="deleteMaturityPlan" data-id="{{item.id}}">删除</text>
      </view>
    </view>

    <view class="editor-panel" wx:if="{{showCashflowEditor}}">
      <view class="editor-grid">
        <view class="editor-field">
          <view class="editor-label">名称</view>
          <input class="editor-input" value="{{cashflowForm.name}}" data-field="name" bindinput="onCashflowFieldInput" placeholder="例如 每月工资 / 房租" />
        </view>
        <view class="editor-field">
          <view class="editor-label">类型</view>
          <picker mode="selector" range="{{cashflowTypeLabels}}" bindchange="onCashflowTypeChange">
            <view class="editor-picker">{{cashflowForm.type === 'outflow' ? '流出' : '流入'}}</view>
          </picker>
        </view>
        <view class="editor-field">
          <view class="editor-label">币种</view>
          <picker mode="selector" range="{{plannerCurrencyLabels}}" bindchange="onCashflowCodeChange">
            <view class="editor-picker">{{cashflowForm.code}}</view>
          </picker>
        </view>
        <view class="editor-field">
          <view class="editor-label">金额</view>
          <input class="editor-input" type="digit" value="{{cashflowForm.amount}}" data-field="amount" bindinput="onCashflowFieldInput" placeholder="例如 3000" />
        </view>
        <view class="editor-field">
          <view class="editor-label">日期</view>
          <picker mode="date" value="{{cashflowForm.dueDate}}" bindchange="onCashflowDateChange">
            <view class="editor-picker">{{cashflowForm.dueDate}}</view>
          </picker>
        </view>
        <view class="editor-field">
          <view class="editor-label">频率</view>
          <picker mode="selector" range="{{cashflowFrequencyLabels}}" bindchange="onCashflowFrequencyChange">
            <view class="editor-picker">{{cashflowForm.frequency === 'monthly' ? '每月' : '一次性'}}</view>
          </picker>
        </view>
      </view>
      <view class="editor-field editor-field-full">
        <view class="editor-label">备注</view>
        <input class="editor-input" value="{{cashflowForm.note}}" data-field="note" bindinput="onCashflowFieldInput" placeholder="可选" />
      </view>
      <view class="editor-actions">
        <view class="editor-btn editor-btn-ghost" bindtap="closeCashflowEditor">取消</view>
        <view class="editor-btn" bindtap="saveCashflowPlan">保存现金流</view>
      </view>
    </view>

    <view class="editor-panel" wx:if="{{showMaturityEditor}}">
      <view class="editor-grid">
        <view class="editor-field">
          <view class="editor-label">名称</view>
          <input class="editor-input" value="{{maturityForm.name}}" data-field="name" bindinput="onMaturityFieldInput" placeholder="例如 美元定存" />
        </view>
        <view class="editor-field">
          <view class="editor-label">币种</view>
          <picker mode="selector" range="{{plannerCurrencyLabels}}" bindchange="onMaturityCodeChange">
            <view class="editor-picker">{{maturityForm.code}}</view>
          </picker>
        </view>
        <view class="editor-field">
          <view class="editor-label">本金</view>
          <input class="editor-input" type="digit" value="{{maturityForm.principal}}" data-field="principal" bindinput="onMaturityFieldInput" placeholder="例如 5000" />
        </view>
        <view class="editor-field">
          <view class="editor-label">到期日</view>
          <picker mode="date" value="{{maturityForm.maturityDate}}" bindchange="onMaturityDateChange">
            <view class="editor-picker">{{maturityForm.maturityDate}}</view>
          </picker>
        </view>
        <view class="editor-field">
          <view class="editor-label">年化利率 %</view>
          <input class="editor-input" type="digit" value="{{maturityForm.apr}}" data-field="apr" bindinput="onMaturityFieldInput" placeholder="例如 2.8" />
        </view>
      </view>
      <view class="editor-field editor-field-full">
        <view class="editor-label">备注</view>
        <input class="editor-input" value="{{maturityForm.note}}" data-field="note" bindinput="onMaturityFieldInput" placeholder="可选" />
      </view>
      <view class="editor-actions">
        <view class="editor-btn editor-btn-ghost" bindtap="closeMaturityEditor">取消</view>
        <view class="editor-btn" bindtap="saveMaturityPlan">保存到期计划</view>
      </view>
    </view>
  </view>

  <view class="empty" wx:if="{{cardCount === 0}}">
    <view class="empty-badge">资产工作台</view>
    <view class="empty-title">还没有银行卡账户</view>
    <view class="empty-text">先补齐第一张银行卡，后面的人民币总览、风险雷达、调仓建议和现金流预测才会真正开始运转。</view>
    <view class="empty-actions">
      <button class="empty-btn" bindtap="gotoAddCard">立即添加</button>
      <view class="empty-link" bindtap="gotoDiagnostics">先检查环境</view>
    </view>
  </view>

  <view class="card-list" wx:else>
    <view class="section-head">
      <view class="section-title">账户清单</view>
      <view class="section-pill">{{cardCount}} 张</view>
    </view>

    <view class="bank-card card" wx:for="{{bankCards}}" wx:key="id">
      <view class="bank-card-shell"></view>
      <view class="bank-card-top" bindtap="gotoAccountDetail" data-cardid="{{item.id}}">
        <view class="bank-card-title-wrap">
          <view class="bank-card-rank">#{{index + 1}}</view>
          <view>
            <view class="bank-card-name">{{item.name}}</view>
            <view class="bank-card-meta">{{item.currencyCount}} 个币种账户</view>
          </view>
        </view>
        <view class="bank-card-total-wrap">
          <view class="bank-card-total-label">折合人民币</view>
          <view class="bank-card-total">{{privacyMode ? '***' : '¥' + item.totalCny}}</view>
        </view>
      </view>

      <view class="bank-card-currencies">
        <view class="bank-card-chip" wx:for="{{item.previewCurrencies}}" wx:key="code">
          <text class="bank-card-chip-code">{{item.code}}</text>
          <text>{{privacyMode ? '***' : item.amount}}</text>
        </view>
      </view>

      <view class="bank-card-actions">
        <text class="bank-card-link" bindtap="gotoAccountDetail" data-cardid="{{item.id}}">查看详情</text>
        <text class="bank-card-link danger" bindtap="deleteCard" data-cardid="{{item.id}}">删除</text>
      </view>
    </view>
  </view>
</view>