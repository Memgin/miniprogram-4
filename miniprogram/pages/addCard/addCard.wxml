<view class="container">
  <view class="page-hero card">
    <view class="page-hero-title">{{mode === 'add' ? '新建银行卡档案' : '编辑银行卡档案'}}</view>
    <view class="page-hero-subtitle">先定义银行主体，再补充该卡下的多币种余额，保存后会自动纳入总资产、风险和目标体系。</view>
    <view class="page-hero-metrics">
      <view class="page-hero-metric">
        <view class="page-hero-label">当前模式</view>
        <view class="page-hero-value">{{mode === 'add' ? '新增' : '编辑'}}</view>
      </view>
      <view class="page-hero-metric">
        <view class="page-hero-label">已录入币种</view>
        <view class="page-hero-value">{{currencyList.length}} 项</view>
      </view>
    </view>
  </view>

  <view class="card card-main">
    <view class="card-title">{{mode === 'add' ? '新增银行卡' : '编辑银行卡'}}</view>
    <view class="form-item">
      <view class="label">银行卡名称</view>
      <input 
        class="input" 
        placeholder="例如：招商银行、工商银行" 
        value="{{cardName}}" 
        bindinput="onCardNameInput"
      />
    </view>
  </view>

  <view class="card card-currency">
    <view class="card-title">币种余额</view>
    <view class="card-subtitle">建议先录入常用主币种，后续可随时补充或修改。</view>
    
    <view class="currency-item" wx:for="{{currencyList}}" wx:key="index">
      <view class="currency-left">
        <text class="currency-name">{{item.name}}</text>
        <text class="currency-amount">{{item.amount}} {{item.codeUpper}}</text>
      </view>
      <view class="currency-right">
        <view class="del-icon" bindtap="delCurrency" data-index="{{index}}">×</view>
      </view>
    </view>

    <view class="add-currency-trigger" bindtap="showAddCurrencyModal">
      <text class="plus">+</text>
      <text>添加/修改币种金额</text>
    </view>
  </view>

  <view class="save-bar card">
    <view class="save-copy">
      <view class="save-title">准备完成后保存</view>
      <view class="save-subtitle">保存会自动同步到首页总资产和云端配置。</view>
    </view>
    <button class="save-btn" bindtap="saveCard">
      {{mode === 'add' ? '确认创建' : '保存修改'}}
    </button>
  </view>
</view>

<view class="modal-mask" wx:if="{{showAddModal}}" bindtap="hideAddModal">
  <view class="modal-content" catchtap="stopPropagation">
    <view class="modal-header">选择币种</view>
    
    <view class="currency-grid">
      <view 
        wx:for="{{allCurrencyList}}" 
        wx:key="code" 
        class="grid-item {{selectedAddCode === item.code ? 'active' : ''}}"
        bindtap="selectAddCurrency" 
        data-code="{{item.code}}" 
        data-name="{{item.name}}"
      >
        {{item.name}}
      </view>
    </view>

    <view class="modal-input-box">
      <text class="modal-label">金额</text>
      <input 
        type="digit" 
        class="modal-input" 
        placeholder="请输入金额" 
        value="{{addAmount}}" 
        bindinput="bindAddAmount"
        focus="{{showAddModal}}"
      />
    </view>

    <view class="modal-btn-group">
      <button class="modal-cancel" bindtap="hideAddModal">取消</button>
      <button class="modal-confirm" bindtap="confirmAddCurrency">确定</button>
    </view>
  </view>
</view>

<view class="custom-toast-mask" wx:if="{{showMergeToast}}" bindtap="hideMergeToast">
  <view class="custom-toast" animation="{{toastAni}}">
    <view class="toast-icon">✓</view>
    <view class="toast-text">已合并到同名银行卡</view>
    <view class="toast-subtext">币种金额已自动累加</view>
  </view>
</view>