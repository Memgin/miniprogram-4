<view class="container">
  <!-- 顶部卡片：银行卡信息 -->
  <view class="card card-main">
    <view class="card-title">{{mode === 'add' ? '新增银行卡' : '编辑银行卡'}}</view>
    <view class="form-item">
      <view class="label">银行卡名称</view>
      <input 
        class="input" 
        placeholder="例如：招商银行、工商银行" 
        value="{{cardName}}" 
        bindinput="onCardNameInput"
      />
    </view>
  </view>

  <!-- 币种余额卡片 -->
  <view class="card card-currency">
    <view class="card-title">币种余额</view>
    <view class="currency-item" wx:for="{{currencyList}}" wx:key="index">
      <view class="currency-left">
        <text class="currency-name">{{item.name}}</text>
        <text class="currency-amount">{{item.amount}}</text>
      </view>
      <view class="currency-right">
        <button class="edit-btn" bindtap="editCurrency" data-index="{{index}}">编辑</button>
        <button class="del-btn" bindtap="delCurrency" data-index="{{index}}">删除</button>
      </view>
    </view>

    <!-- 快速添加区域 -->
    <view class="add-currency-area">
      <picker bindchange="onCurrencyChange" value="{{currIndex}}" range="{{currencyNameList}}">
        <view class="picker">{{currencyNameList[currIndex]}}</view>
      </picker>
      <input 
        class="input-amount" 
        type="digit" 
        placeholder="输入金额" 
        value="{{currAmount}}" 
        bindinput="onAmountInput"
      />
      <button class="add-btn" bindtap="addCurrency">+</button>
    </view>
  </view>

  <!-- 确认创建 / 保存 -->
  <button class="save-btn" bindtap="saveCard">
    {{mode === 'add' ? '确认创建' : '保存修改'}}
  </button>
</view>

<!-- 自定义合并成功弹窗（核心新增） -->
<!-- 自定义合并成功弹窗（替换后版，兼容所有库） -->
<view class="custom-toast-mask" wx:if="{{showMergeToast}}" bindtap="hideMergeToast">
  <view class="custom-toast" animation="{{toastAni}}">
    <view class="toast-icon">✓</view>
    <view class="toast-text">已合并到同名银行卡</view>
    <view class="toast-subtext">币种金额已自动累加</view>
  </view>
</view>