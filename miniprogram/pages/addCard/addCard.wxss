.container {
  padding: 24rpx;
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(251, 191, 36, 0.12), transparent 24%),
    linear-gradient(180deg, #f8fbff 0%, #f3f7fb 100%);
}

.page-hero {
  padding: 34rpx;
  margin-bottom: 22rpx;
  background: linear-gradient(135deg, #14263f, #0f766e 60%, #22c55e);
  color: #ffffff;
}

.page-hero-title {
  font-size: 38rpx;
  font-weight: 700;
}

.page-hero-subtitle {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.78);
}

.page-hero-metrics {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.page-hero-metric {
  flex: 1;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.16);
}

.page-hero-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.72);
}

.page-hero-value {
  margin-top: 10rpx;
  font-size: 30rpx;
  font-weight: 700;
}

/* 卡片通用 */
.card {
  background: rgba(255, 255, 255, 0.94);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 16rpx 34rpx rgba(15, 23, 42, 0.06);
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.card-subtitle {
  margin-bottom: 20rpx;
  font-size: 23rpx;
  line-height: 1.6;
  color: #64748b;
}

/* 表单与输入框 */
.form-item {
  margin-bottom: 10rpx;
}

.label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  border-radius: 12rpx;
  background: #f7f8fa;
  border: 1rpx solid #e5e6eb;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 币种条目列表 */
.currency-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.currency-left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.currency-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.currency-amount {
  font-size: 24rpx;
  color: #888;
}

/* 列表中的删除叉号 */
.del-icon {
  width: 44rpx;
  height: 44rpx;
  line-height: 40rpx;
  text-align: center;
  background: #fff1f0;
  color: #ff4d4f;
  border-radius: 50%;
  font-size: 32rpx;
}

/* 核心：添加币种触发区域 */
.add-currency-trigger {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx;
  border: 2rpx dashed #ffbd69; /* 使用浅橘色虚线 */
  border-radius: 16rpx;
  color: #ff9f43; /* 活力橘 */
  font-size: 28rpx;
  margin-top: 30rpx;
  background: #fffcf9;
}

.add-currency-trigger .plus {
  font-size: 36rpx;
  margin-right: 12rpx;
  font-weight: bold;
}

/* 底部保存按钮 */
.save-btn {
  width: 100%;
  height: 94rpx;
  line-height: 94rpx;
  margin: 18rpx 0 0;
  background: linear-gradient(135deg, #f97316, #f59e0b);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 47rpx; /* 圆角矩形 */
  box-shadow: 0 14rpx 28rpx rgba(249, 115, 22, 0.22);
}

.save-bar {
  padding: 26rpx;
  position: sticky;
  bottom: 20rpx;
}

.save-copy {
  margin-bottom: 8rpx;
}

.save-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #0f172a;
}

.save-subtitle {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #64748b;
}

/* --- 模态弹窗样式 (仿 accountDetail) --- */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  backdrop-filter: blur(4px); /* 增加磨砂效果 */
}

.modal-content {
  width: 85%;
  background: #fff;
  border-radius: 30rpx;
  padding: 40rpx;
  box-sizing: border-box;
}

.modal-header {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  color: #333;
  margin-bottom: 30rpx;
}

/* 币种网格 */
.currency-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  max-height: 400rpx; /* 防止币种太多撑破屏幕 */
  overflow-y: auto;
  padding: 10rpx 0;
}

.grid-item {
  padding: 20rpx 0;
  text-align: center;
  font-size: 26rpx;
  background: #f7f8fa;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  color: #666;
  transition: all 0.2s;
}

.grid-item.active {
  background: #fff5eb;
  border-color: #ff9f43;
  color: #ff9f43;
  font-weight: bold;
}

/* 弹窗输入框 */
.modal-input-box {
  margin-top: 40rpx;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.modal-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
  display: block;
}

.modal-input {
  height: 80rpx;
  font-size: 40rpx;
  font-weight: 500;
  color: #ff9f43;
}

/* 按钮组 */
.modal-btn-group {
  display: flex;
  margin-top: 50rpx;
  gap: 20rpx;
}

.modal-cancel {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  background: #f5f5f5;
  color: #666;
  font-size: 28rpx;
  border-radius: 40rpx;
}

.modal-confirm {
  flex: 2;
  height: 80rpx;
  line-height: 80rpx;
  background: #ff9f43;
  color: #fff;
  font-size: 28rpx;
  border-radius: 40rpx;
}

/* 你的合并成功 Toast 保持不变 */
.custom-toast-mask {
  position: fixed;
  top: 0; left: 0; width: 100vw; height: 100vh;
  background: rgba(0, 0, 0, 0.3);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}
.custom-toast {
  background: #fff;
  padding: 40rpx 50rpx;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.15);
  min-width: 280rpx;
}
.toast-icon {
  font-size: 60rpx;
  color: #ff9f43; /* 改为主橘色 */
  line-height: 60rpx;
}
.toast-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}
.toast-subtext {
  font-size: 24rpx;
  color: #666;
}