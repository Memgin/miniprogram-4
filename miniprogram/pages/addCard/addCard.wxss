.container {
  padding: 24rpx;
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(251, 191, 36, 0.12), transparent 24%),
    linear-gradient(180deg, #f8fbff 0%, #f3f7fb 100%);
}

.page-hero {
  padding: 34rpx;
  margin-bottom: 22rpx;
  background: linear-gradient(135deg, #14263f, #0f766e 60%, #22c55e);
  color: #ffffff;
}

.page-hero-title {
  font-size: 38rpx;
  font-weight: 700;
}

.page-hero-subtitle {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.78);
}

.page-hero-metrics {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.page-hero-metric {
  flex: 1;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.16);
}

.page-hero-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.72);
}

.page-hero-value {
  margin-top: 10rpx;
  font-size: 30rpx;
  font-weight: 700;
}

/* 卡片通用 */
.card {
  background: rgba(255, 255, 255, 0.94);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 16rpx 34rpx rgba(15, 23, 42, 0.06);
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.card-subtitle {
  margin-bottom: 20rpx;
  font-size: 23rpx;
  line-height: 1.6;
  color: #64748b;
}

/* 表单与输入框 */
.form-item {
  margin-bottom: 10rpx;
}

.label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  border-radius: 12rpx;
  background: #f7f8fa;
  border: 1rpx solid #e5e6eb;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 币种条目列表 */
.currency-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.currency-left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.currency-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.currency-amount {
  font-size: 24rpx;
  color: #888;
}

/* 列表中的删除叉号 */
.del-icon {
  width: 44rpx;
  height: 44rpx;
  line-height: 40rpx;
  text-align: center;
  background: #fff1f0;
  color: #ff4d4f;
  border-radius: 50%;
  font-size: 32rpx;
}

/* 核心：添加币种触发区域 */
.add-currency-trigger {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx;
  border: 2rpx dashed #ffbd69; /* 使用浅橘色虚线 */
  border-radius: 16rpx;
  color: #ff9f43; /* 活力橘 */
  font-size: 28rpx;
  margin-top: 30rpx;
  background: #fffcf9;
}

.add-currency-trigger .plus {
  font-size: 36rpx;
  margin-right: 12rpx;
  font-weight: bold;
}

/* 底部保存按钮 */
.save-btn {
  width: 100%;
  height: 94rpx;
  line-height: 94rpx;
  margin: 18rpx 0 0;
  background: linear-gradient(135deg, #f97316, #f59e0b);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 47rpx; /* 圆角矩形 */
  box-shadow: 0 14rpx 28rpx rgba(249, 115, 22, 0.22);
}

.save-bar {
  padding: 26rpx;
  position: sticky;
  bottom: 20rpx;
}

.save-copy {
  margin-bottom: 8rpx;
}

.save-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #0f172a;
}

.save-subtitle {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #64748b;
}

/* --- 模态弹窗样式 (仿 accountDetail) --- */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  backdrop-filter: blur(4px); /* 增加磨砂效果 */
}

.modal-content {
  width: 85%;
  background: #fff;
  border-radius: 30rpx;
  padding: 40rpx;
  box-sizing: border-box;
}

.modal-header {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  color: #333;
  margin-bottom: 30rpx;
}

/* 币种网格 */
.currency-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  max-height: 400rpx; /* 防止币种太多撑破屏幕 */
  overflow-y: auto;
  padding: 10rpx 0;
}

.grid-item {
  padding: 20rpx 0;
  text-align: center;
  font-size: 26rpx;
  background: #f7f8fa;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  color: #666;
  transition: all 0.2s;
}

.grid-item.active {
  background: #fff5eb;
  border-color: #ff9f43;
  color: #ff9f43;
  font-weight: bold;
}

/* 弹窗输入框 */
.modal-input-box {
  margin-top: 40rpx;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.modal-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
  display: block;
}

.modal-input {
  height: 80rpx;
  font-size: 40rpx;
  font-weight: 500;
  color: #ff9f43;
}

/* 按钮组 */
.modal-btn-group {
  display: flex;
  margin-top: 50rpx;
  gap: 20rpx;
}

.modal-cancel {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  background: #f5f5f5;
  color: #666;
  font-size: 28rpx;
  border-radius: 40rpx;
}

.modal-confirm {
  flex: 2;
  height: 80rpx;
  line-height: 80rpx;
  background: #ff9f43;
  color: #fff;
  font-size: 28rpx;
  border-radius: 40rpx;
}

/* 你的合并成功 Toast 保持不变 */
.custom-toast-mask {
  position: fixed;
  top: 0; left: 0; width: 100vw; height: 100vh;
  background: rgba(0, 0, 0, 0.3);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}
.custom-toast {
  background: #fff;
  padding: 40rpx 50rpx;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.15);
  min-width: 280rpx;
}
.toast-icon {
  font-size: 60rpx;
  color: #ff9f43; /* 改为主橘色 */
  line-height: 60rpx;
}
.toast-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}
.toast-subtext {
  font-size: 24rpx;
  color: #666;
}

/* Liquid Glass Harmonization */
.container {
  background:
    radial-gradient(circle at 12% -10%, rgba(143, 244, 120, 0.18) 0%, rgba(143, 244, 120, 0) 28%),
    radial-gradient(circle at 90% -8%, rgba(145, 214, 255, 0.2) 0%, rgba(145, 214, 255, 0) 28%),
    linear-gradient(170deg, #f8fbff 0%, #edf1f8 100%);
}

.card,
.modal-content,
.page-hero-metric,
.currency-item {
  background: linear-gradient(150deg, rgba(255, 255, 255, 0.84), rgba(255, 255, 255, 0.64));
  border: 1rpx solid rgba(255, 255, 255, 0.56);
  backdrop-filter: blur(14rpx) saturate(1.14);
  -webkit-backdrop-filter: blur(14rpx) saturate(1.14);
}

.save-btn,
.modal-confirm {
  background: linear-gradient(140deg, #151d2f, #0c1324);
  color: #ffffff;
}

.modal-cancel {
  background: rgba(255, 255, 255, 0.76);
  color: #6b7280;
}

/* System polish */
.page-hero,
.card,
.modal-content,
.save-bar {
  border-radius: 24rpx;
}

.card-title,
.page-hero-title,
.save-title {
  letter-spacing: 0.2rpx;
}

/* Liquid Glass Unified Final Override */
.container {
  background:
    radial-gradient(circle at 12% -8%, rgba(255, 255, 255, 0.4) 0%, rgba(255, 255, 255, 0) 30%),
    radial-gradient(circle at 90% 6%, rgba(214, 194, 168, 0.22) 0%, rgba(214, 194, 168, 0) 30%),
    linear-gradient(180deg, #f6f4f1 0%, #f1eee9 100%) !important;
}

.card,
.modal-content,
.page-hero,
.page-hero-metric,
.currency-item,
.save-bar {
  background: linear-gradient(154deg, rgba(255, 255, 255, 0.74), rgba(247, 241, 233, 0.56)) !important;
  border: 1rpx solid rgba(255, 255, 255, 0.72) !important;
  backdrop-filter: blur(14rpx) saturate(1.03);
  -webkit-backdrop-filter: blur(14rpx) saturate(1.03);
  box-shadow: 0 10rpx 24rpx rgba(66, 53, 39, 0.09) !important;
}

.save-btn,
.modal-confirm,
.modal-cancel {
  background: linear-gradient(148deg, rgba(255, 255, 255, 0.82), rgba(243, 234, 224, 0.64)) !important;
  border: 1rpx solid rgba(255, 255, 255, 0.74) !important;
  color: #63513d !important;
}

.save-btn,
.modal-confirm {
  background: linear-gradient(140deg, #7a6348, #5f4d39) !important;
  color: #fff8ef !important;
  border-color: rgba(255, 255, 255, 0.42) !important;
}

/* Liquid Glass Main Inspired Finish */
.container {
  background:
    radial-gradient(circle at 14% -10%, rgba(255, 255, 255, 0.46) 0%, rgba(255, 255, 255, 0) 32%),
    radial-gradient(circle at 90% 8%, rgba(220, 198, 170, 0.22) 0%, rgba(220, 198, 170, 0) 30%),
    linear-gradient(180deg, #f6f4f1 0%, #f1eee9 100%) !important;
}

.card,
.modal-content,
.page-hero,
.page-hero-metric,
.currency-item,
.save-bar {
  background: linear-gradient(160deg, rgba(255, 255, 255, 0.84), rgba(243, 235, 226, 0.58)) !important;
  border: 1rpx solid rgba(255, 255, 255, 0.78) !important;
  box-shadow: 0 8rpx 18rpx rgba(0, 0, 0, 0.16), 0 -16rpx 28rpx inset rgba(0, 0, 0, 0.08), 0 1rpx 0 inset rgba(255, 255, 255, 0.78) !important;
  backdrop-filter: blur(16rpx) contrast(1.12) brightness(1.03) saturate(1.08);
  -webkit-backdrop-filter: blur(16rpx) contrast(1.12) brightness(1.03) saturate(1.08);
}

/* AddCard Page Stabilization (Absolute EOF) */
.container {
  padding: 24rpx 24rpx 40rpx;
}

.modal-mask {
  background: rgba(15, 23, 42, 0.38);
  backdrop-filter: blur(10rpx) saturate(1.04);
  -webkit-backdrop-filter: blur(10rpx) saturate(1.04);
  padding: 30rpx;
  box-sizing: border-box;
}

.modal-content {
  width: 100%;
  max-width: 650rpx;
  max-height: 78vh;
  padding: 34rpx 30rpx 28rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.modal-header {
  margin-bottom: 20rpx;
  line-height: 1.3;
  color: #2f271d;
}

.currency-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  max-height: none;
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  padding: 4rpx 4rpx 12rpx;
  margin-bottom: 18rpx;
}

.grid-item {
  min-height: 72rpx;
  padding: 0 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1.2;
}

.modal-input-box {
  margin-top: 0;
  padding: 14rpx 2rpx 18rpx;
  border-bottom: 1rpx solid rgba(201, 186, 167, 0.45);
}

.modal-label {
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 8rpx;
  color: #7a6a58;
}

.modal-input {
  height: 76rpx;
  line-height: 76rpx;
  padding: 0 18rpx;
  box-sizing: border-box;
  border-radius: 14rpx;
  border: 1rpx solid rgba(201, 186, 167, 0.5);
  background: rgba(255, 255, 255, 0.8);
  font-size: 42rpx;
  color: #5f4d39;
}

.modal-input::placeholder {
  font-size: 42rpx;
  color: #a09a90;
}

.modal-btn-group {
  margin-top: 22rpx;
  flex-shrink: 0;
}

/* Rounded Beauty Tuning (Currency Section) */
.card-currency {
  border-radius: 28rpx !important;
}

.currency-item {
  margin-bottom: 14rpx;
  padding: 22rpx 20rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.82);
  border-bottom: none;
  background: linear-gradient(158deg, rgba(255, 255, 255, 0.86), rgba(245, 237, 227, 0.62));
}

.currency-item:last-of-type {
  margin-bottom: 0;
}

.currency-left {
  gap: 10rpx;
}

.currency-name {
  font-size: 34rpx;
  line-height: 1.2;
}

.currency-amount {
  font-size: 36rpx;
  line-height: 1.2;
  color: #6a5a47;
}

.del-icon {
  width: 52rpx;
  height: 52rpx;
  line-height: 48rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 117, 117, 0.26);
  background: rgba(255, 117, 117, 0.12);
  font-size: 34rpx;
}

.add-currency-trigger {
  min-height: 108rpx;
  padding: 0 28rpx;
  margin-top: 22rpx;
  border-radius: 24rpx;
  border: 1rpx dashed rgba(244, 162, 78, 0.68);
  background: linear-gradient(155deg, rgba(255, 252, 247, 0.92), rgba(251, 244, 234, 0.72));
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
  font-size: 40rpx;
  font-weight: 600;
  line-height: 1;
}

.add-currency-trigger .plus {
  font-size: 44rpx;
  margin-right: 14rpx;
}