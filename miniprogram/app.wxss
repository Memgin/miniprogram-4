:root {
  --lg-text: #3a3026;
  --lg-muted: #7c6f60;
  --lg-stroke: rgba(255, 255, 255, 0.78);
  --lg-surface: rgba(243, 235, 226, 0.58);
  --lg-surface-strong: rgba(255, 255, 255, 0.84);
  --lg-shadow: 0 8rpx 18rpx rgba(0, 0, 0, 0.16), 0 -16rpx 28rpx inset rgba(0, 0, 0, 0.08), 0 1rpx 0 inset rgba(255, 255, 255, 0.78);
  --lg-accent: #7c6548;
  --lg-accent-dark: #5d4d39;
  --lg-font-sans: "SF Pro Text", "PingFang SC", "Hiragino Sans GB", "Noto Sans CJK SC", "Microsoft YaHei", sans-serif;
  --lg-font-display: "SF Pro Display", "PingFang SC", "Hiragino Sans GB", "Noto Sans CJK SC", "Microsoft YaHei", sans-serif;
}

page {
  font-size: 28rpx;
  color: var(--lg-text);
  font-family: var(--lg-font-sans);
  background:
    radial-gradient(circle at 10% -8%, rgba(255, 255, 255, 0.42) 0%, rgba(255, 255, 255, 0) 30%),
    radial-gradient(circle at 92% 6%, rgba(216, 196, 171, 0.24) 0%, rgba(216, 196, 171, 0) 30%),
    linear-gradient(180deg, #f6f4f1 0%, #f1eee9 100%);
}

view,
text,
button,
input,
picker,
scroll-view,
swiper,
swiper-item {
  font-family: var(--lg-font-sans);
  box-sizing: border-box;
}

.card {
  background: linear-gradient(160deg, var(--lg-surface-strong) 0%, var(--lg-surface) 100%);
  border: 1rpx solid var(--lg-stroke);
  border-radius: 24rpx;
  box-shadow: var(--lg-shadow);
  backdrop-filter: blur(16rpx) contrast(1.12) brightness(1.03) saturate(1.08);
  -webkit-backdrop-filter: blur(16rpx) contrast(1.12) brightness(1.03) saturate(1.08);
  animation: card-fade-up 320ms ease both;
}

.btn {
  border-radius: 999rpx;
  font-size: 28rpx;
  padding: 20rpx 0;
}

button {
  border: none;
  background: linear-gradient(160deg, rgba(255, 255, 255, 0.86), rgba(243, 234, 224, 0.68));
  border: 1rpx solid var(--lg-stroke);
  box-shadow: 0 6rpx 14rpx rgba(0, 0, 0, 0.14), 0 -10rpx 18rpx inset rgba(0, 0, 0, 0.06), 0 1rpx 0 inset rgba(255, 255, 255, 0.72);
  transition: transform 160ms ease, opacity 160ms ease, box-shadow 160ms ease, filter 160ms ease;
}

button::after {
  border: none;
}

button:active {
  transform: translateY(2rpx) scale(0.985);
  opacity: 0.94;
  filter: saturate(0.92);
}

input,
textarea {
  border: 1rpx solid rgba(255, 255, 255, 0.68);
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(8rpx) saturate(1.06);
  -webkit-backdrop-filter: blur(8rpx) saturate(1.06);
}

.glass-pill {
  border: 1rpx solid rgba(255, 255, 255, 0.58);
  background: linear-gradient(160deg, rgba(255, 255, 255, 0.78), rgba(243, 234, 224, 0.58));
  border-radius: 999rpx;
  backdrop-filter: blur(16rpx) contrast(1.12) brightness(1.03) saturate(1.08);
  -webkit-backdrop-filter: blur(16rpx) contrast(1.12) brightness(1.03) saturate(1.08);
}

/* Unified top custom navigation for all pages */
.custom-nav {
  position: relative;
  margin: 0 0 12rpx;
  padding-left: 8rpx;
  padding-right: 8rpx;
  background: transparent;
  border: none;
  box-shadow: none;
  overflow: visible;
}

.custom-nav::after {
  content: none;
}

.custom-nav-inner {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
  width: 100%;
  padding: 0 8rpx;
  border-radius: 0;
  background: transparent;
  border: none;
  box-shadow: none;
  backdrop-filter: none;
  -webkit-backdrop-filter: none;
  overflow: visible;
}

.custom-nav-side {
  flex-shrink: 0;
  min-width: 88rpx;
  display: flex;
  align-items: center;
}

.custom-nav-side-right {
  justify-content: flex-end;
}

.custom-nav-back {
  display: inline-flex;
  align-items: center;
  justify-content: flex-start;
  width: 56rpx;
  height: 56rpx;
  border: none;
  background: transparent;
  box-shadow: none;
  font-size: 42rpx;
  font-weight: 500;
  line-height: 1;
  padding-left: 0;
  color: #2f271d;
  transition: opacity 120ms ease, transform 120ms ease;
}

.custom-nav-back:active {
  opacity: 0.62;
  transform: translateX(-1rpx);
}

.custom-nav-title {
  flex: 1;
  min-width: 0;
  text-align: center;
  font-family: var(--lg-font-display);
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: 0.6rpx;
  color: #2f271d;
  text-shadow: none;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* System typography and control rhythm */
.page-title,
.hero-title,
.overview-title,
.section-title,
.card-title,
.detail-card-title,
.preview-title,
.diagnostic-title {
  font-family: var(--lg-font-display);
  letter-spacing: 0.35rpx;
  font-weight: 700;
}

.page-subtitle,
.hero-subtitle,
.section-subtitle,
.card-subtitle,
.tips,
.empty-text,
.preview-subtitle,
.diagnostic-desc {
  font-family: var(--lg-font-sans);
  font-weight: 500;
  letter-spacing: 0.18rpx;
  line-height: 1.65;
}

.save-btn,
.run-btn,
.empty-btn,
.hero-btn,
.hero-btn-primary,
.hero-action-btn,
.export-hero-btn,
.export-hero-btn-primary,
.detail-delete-btn,
.price-currency-confirm,
.price-currency-cancel,
.modal-confirm,
.modal-cancel {
  font-family: var(--lg-font-display);
  font-weight: 650;
  letter-spacing: 0.24rpx;
  min-height: 72rpx;
  border-radius: 999rpx;
}

input,
textarea,
input::placeholder,
textarea::placeholder {
  font-family: var(--lg-font-sans);
}

@keyframes card-fade-up {
  from {
    opacity: 0;
    transform: translateY(18rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

