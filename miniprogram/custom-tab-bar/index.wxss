.lg-tabbar-wrap {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  padding: 0 24rpx calc(18rpx + env(safe-area-inset-bottom));
  pointer-events: none;
}

.lg-tabbar-glow {
  position: absolute;
  left: 42rpx;
  right: 42rpx;
  bottom: calc(10rpx + env(safe-area-inset-bottom));
  height: 86rpx;
  border-radius: 999rpx;
  background: radial-gradient(circle at 50% 0%, rgba(255, 255, 255, 0.42) 0%, rgba(255, 255, 255, 0) 72%);
  filter: blur(10rpx);
  pointer-events: none;
}

.lg-tabbar-shell {
  position: relative;
  display: flex;
  gap: 14rpx;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.68);
  background: linear-gradient(162deg, rgba(255, 255, 255, 0.74), rgba(241, 232, 221, 0.48));
  box-shadow: 0 8rpx 18rpx rgba(0, 0, 0, 0.16), 0 -14rpx 24rpx inset rgba(0, 0, 0, 0.08), 0 1rpx 0 inset rgba(255, 255, 255, 0.82);
  backdrop-filter: blur(18rpx) contrast(1.12) brightness(1.03) saturate(1.08);
  -webkit-backdrop-filter: blur(18rpx) contrast(1.12) brightness(1.03) saturate(1.08);
  pointer-events: auto;
  overflow: hidden;
}

.lg-tab-dynamic-highlight {
  position: absolute;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  transform: translate(-50%, -50%);
  background: radial-gradient(circle, rgba(255, 255, 255, 0.42) 0%, rgba(255, 255, 255, 0.1) 34%, rgba(255, 255, 255, 0) 70%);
  filter: blur(2rpx);
  opacity: 0.42;
  transition: left 120ms ease-out, top 120ms ease-out, opacity 220ms ease;
  pointer-events: none;
}

.lg-tab-dynamic-highlight.is-tracking {
  opacity: 0.6;
  transition: opacity 140ms ease;
}

.lg-tab-item {
  position: relative;
  overflow: hidden;
  flex: 1;
  min-height: 84rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 0 16rpx;
  transition: transform 140ms ease, box-shadow 180ms ease, background 180ms ease;
  z-index: 2;
}

.lg-tabbar-shell.is-sliding .lg-tab-item {
  transition: transform 70ms linear, box-shadow 100ms linear, background 100ms linear;
}

.lg-tab-item.is-active {
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.62), rgba(238, 226, 211, 0.42));
  border: 1rpx solid rgba(255, 255, 255, 0.62);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1), 0 1rpx 0 inset rgba(255, 255, 255, 0.86);
  transform: translateY(-3rpx);
  animation: lg-tab-float 2400ms ease-in-out infinite;
}

.lg-tab-item.is-pressed {
  transform: translateY(1rpx) scale(0.976);
}

.lg-tab-item.is-active.is-pressed {
  transform: translateY(-1rpx) scale(0.98);
}

.lg-tab-active-halo {
  position: absolute;
  inset: 8rpx;
  border-radius: 999rpx;
  background: linear-gradient(140deg, rgba(255, 255, 255, 0.3), rgba(255, 255, 255, 0));
  pointer-events: none;
}

.lg-tab-icon-shell {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.28);
}

.lg-tab-item.is-active .lg-tab-icon-shell {
  background: rgba(255, 255, 255, 0.58);
  box-shadow: 0 1rpx 0 inset rgba(255, 255, 255, 0.9);
}

.lg-tab-icon {
  width: 34rpx;
  height: 34rpx;
}

.lg-tab-text {
  font-size: 22rpx;
  color: #8c7a64;
  font-weight: 500;
  letter-spacing: 0.2rpx;
}

.lg-tab-item.is-active .lg-tab-text {
  color: #4d3e2f;
  font-weight: 700;
}

@keyframes lg-tab-float {
  0% {
    transform: translateY(-3rpx);
  }

  50% {
    transform: translateY(-6rpx);
  }

  100% {
    transform: translateY(-3rpx);
  }
}
